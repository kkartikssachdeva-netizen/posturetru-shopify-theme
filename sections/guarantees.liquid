<section class="section-padding" style="background-color: var(--color-bg); border-top: 1px solid var(--color-border);">
  <div class="container grid guarantees-grid">
    <!-- Guarantee 1 -->
    <div class="guarantee-item">
      <div class="guarantee-icon">
        {% render 'icon-shield' %}
      </div>
      <h4>30 Day Money Back</h4>
      <p>Not satisfied? Return it within 30 days for a full refund.</p>
    </div>

    <!-- Guarantee 2 -->
    <div class="guarantee-item">
      <div class="guarantee-icon">
        {% render 'icon-truck' %}
      </div>
      <h4>Free Tracked Shipping</h4>
      <p>Free tracked delivery to Canada, Australia, UK & NZ.</p>
    </div>

    <!-- Guarantee 3 -->
    <div class="guarantee-item">
      <div class="guarantee-icon">
        {% render 'icon-support' %}
      </div>
      <h4>Customer Support</h4>
      <p>Our support team typically responds within 24 hours to help with your order or setup.</p>
    </div>

    <!-- Guarantee 4 -->
    <div class="guarantee-item">
      <div class="guarantee-icon">
        {% render 'icon-warranty' %}
      </div>
      <h4>Quality Guarantee</h4>
      <p>Backed by quality materials and manufacturer support if something isn't right.</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Guarantees",
  "settings": []
}
{% endschema %}
