<section class="section-padding" style="background-color: var(--color-bg); border-top: 1px solid var(--color-border);">
  <div class="container grid guarantees-grid">
    <!-- Guarantee 1 -->
    <div class="guarantee-item">
      <div class="guarantee-icon">
        {% render 'icon-shield' %}
      </div>
      <h4>30-Day Money-Back</h4>
      <p>Not satisfied? Return it within 30 days for a full refund—no questions asked.</p>
    </div>

    <!-- Guarantee 2 -->
    <div class="guarantee-item">
      <div class="guarantee-icon">
        {% render 'icon-truck' %}
      </div>
      <h4>Free Tracked Shipping</h4>
      <p>Free tracked delivery to Canada, Australia, UK & NZ addresses.</p>
    </div>

    <!-- Guarantee 3 -->
    <div class="guarantee-item">
      <div class="guarantee-icon">
        {% render 'icon-support' %}
      </div>
      <h4>Lifetime Support</h4>
      <p>Our dedicated support team is available 24/7 to help you with sizing or setup.</p>
    </div>

    <!-- Guarantee 4 -->
    <div class="guarantee-item">
      <div class="guarantee-icon">
        {% render 'icon-warranty' %}
      </div>
      <h4>2-Year Warranty</h4>
      <p>Covers all manufacturer defects and electronic component failures.</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Guarantees",
  "settings": []
}
{% endschema %}
