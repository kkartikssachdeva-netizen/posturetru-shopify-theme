<section class="section-padding" style="background-color: var(--color-bg-light); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
  <div class="container specs-layout">
    <!-- What's Included -->
    <div class="specs-included">
      <h3>What's in the Box?</h3>
      <ul class="included-list">
        <li>1× PostureTru Smart Posture Corrector</li>
        <li>1× USB Charging Cable</li>
        <li>1× English User Manual</li>
        <li><strong>FREE Bonus:</strong> "Perfect Posture" eBook (PDF digital download sent via email)</li>
      </ul>
    </div>
    
    <!-- Specs Table -->
    <div>
      <h3 style="margin-bottom: 24px;">Technical Specifications</h3>
      <table class="specs-table">
        <tbody>
          <tr>
            <td class="specs-label">Material</td>
            <td class="specs-val">Food-grade silicone + imported ABS</td>
          </tr>
          <tr>
            <td class="specs-label">Color</td>
            <td class="specs-val">Black</td>
          </tr>
          <tr>
            <td class="specs-label">Dimensions</td>
            <td class="specs-val">18.5 × 14.5 × 2 cm</td>
          </tr>
          <tr>
            <td class="specs-label">Weight</td>
            <td class="specs-val">90g</td>
          </tr>
          <tr>
            <td class="specs-label">Feedback System</td>
            <td class="specs-val">High-precision gyroscope chip — vibrates on slouch detection</td>
          </tr>
          <tr>
            <td class="specs-label">Rated Input</td>
            <td class="specs-val">5V / 1A</td>
          </tr>
          <tr>
            <td class="specs-label">Battery Capacity</td>
            <td class="specs-val">200mAh / 3.7V</td>
          </tr>
          <tr>
            <td class="specs-label">Battery Life</td>
            <td class="specs-val">~7 days (based on 4 hours/day use)</td>
          </tr>
          <tr>
            <td class="specs-label">Rated Power</td>
            <td class="specs-val">2W</td>
          </tr>
          <tr>
            <td class="specs-label">Care Instructions</td>
            <td class="specs-val">Hand wash gently with mild soap, air dry only</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Specifications",
  "settings": []
}
{% endschema %}
