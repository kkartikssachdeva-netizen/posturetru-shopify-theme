<section class="section-padding" style="background-color: var(--color-bg-light); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
  <div class="container specs-layout">
    <!-- What's Included -->
    <div class="specs-included">
      <h3>What's in the Box?</h3>
      <ul class="included-list">
        <li>1x PostureTru Smart Magnetic Posture Belt</li>
        <li>1x USB Charging Cable for Smart Sensor</li>
        <li>1x Sizing & Fitment User Guide</li>
        <li><strong>FREE Bonus:</strong> "Perfect Posture" ebook (PDF digital download sent via email)</li>
      </ul>
    </div>
    
    <!-- Specs Table -->
    <div>
      <h3 style="margin-bottom: 24px;">Technical Specifications</h3>
      <table class="specs-table">
        <tbody>
          <tr>
            <td class="specs-label">Material</td>
            <td class="specs-val">Medical-grade neoprene and breathable mesh lining</td>
          </tr>
          <tr>
            <td class="specs-label">Magnetic Nodes</td>
            <td class="specs-val">10 integrated therapeutic acupressure magnets</td>
          </tr>
          <tr>
            <td class="specs-label">Feedback System</td>
            <td class="specs-val">Micro-vibrational smart angle sensor (vibrates at >25° slouch)</td>
          </tr>
          <tr>
            <td class="specs-label">Waist Sizing</td>
            <td class="specs-val">One size fits all (adjustable chest girth 28"-50")</td>
          </tr>
          <tr>
            <td class="specs-label">Product Weight</td>
            <td class="specs-val">0.35 lbs (lightweight, non-obstructive)</td>
          </tr>
          <tr>
            <td class="specs-label">Care Instructions</td>
            <td class="specs-val">Hand wash gently with mild soap, air dry only (remove sensor module before wash)</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Specifications",
  "settings": []
}
{% endschema %}
