<section class="section-padding">
  <div class="container">
    <div class="section-header">
      <h2>{{ section.settings.title | default: 'Frequently Asked Questions' }}</h2>
      <p>{{ section.settings.subtitle | default: 'Have questions? We have answers.' }}</p>
    </div>

    <div class="faq-accordion-container">
      {% capture faq_json %}{% render 'faq-data' %}{% endcapture %}
      {% assign faq_items = faq_json | parse_json %}
      {% assign accordion_ids = "results,under-clothes,all-day-wear,care,returns" | split: "," %}
      {% for id in accordion_ids %}
        {% assign item = faq_items | where: "id", id | first %}
        {% render 'faq-item', item: item %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ Accordion",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Have questions? We have answers."
    }
  ]
}
{% endschema %}
