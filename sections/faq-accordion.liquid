<section class="section-padding">
  <div class="container">
    <div class="section-header">
      <h2>{{ section.settings.title | default: 'Frequently Asked Questions' }}</h2>
      <p>{{ section.settings.subtitle | default: 'Have questions? We have answers.' }}</p>
    </div>

    <div class="faq-accordion-container">
      {% include 'faq-data' %}
      {% render 'faq-item', id: 'results', question: faq_q_results, answer: faq_a_results %}
      {% render 'faq-item', id: 'under-clothes', question: faq_q_under_clothes, answer: faq_a_under_clothes %}
      {% render 'faq-item', id: 'all-day-wear', question: faq_q_all_day_wear, answer: faq_a_all_day_wear %}
      {% render 'faq-item', id: 'care', question: faq_q_care, answer: faq_a_care %}
      {% render 'faq-item', id: 'returns', question: faq_q_returns, answer: faq_a_returns %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ Accordion",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Have questions? We have answers."
    }
  ]
}
{% endschema %}
