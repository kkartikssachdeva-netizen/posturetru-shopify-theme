<section class="section-padding" style="background-color: var(--color-bg-light); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
  <div class="container" style="max-width: 700px; text-align: center; margin-left: auto; margin-right: auto;">
    <p style="font-size: clamp(18px, 2.5vw, 24px); line-height: 1.6; color: var(--color-text-primary);">{{ section.settings.statement | default: "PostureTru is committed to restoring the awareness that a busy day quietly erodes. Verta is where that starts, not where it ends." }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Brand Statement",
  "settings": [
    {
      "type": "textarea",
      "id": "statement",
      "label": "Statement",
      "default": "PostureTru is committed to restoring the awareness that a busy day quietly erodes. Verta is where that starts, not where it ends."
    }
  ]
}
{% endschema %}
