<footer style="margin-top: auto;">
  <div class="footer-top">
    <div class="container grid grid-3">
      <!-- Col 1: About Brand -->
      <div class="footer-col">
        <a href="/" class="logo logo--image" aria-label="PostureTru home" style="margin-bottom: 16px; display: block;">
          <img
            src="https://cdn.shopify.com/s/files/1/0839/9274/0080/files/PostureTru_logo.png"
            alt="PostureTru"
            class="logo-img logo-img--footer"
            width="160"
            height="38"
            loading="lazy"
          >
        </a>
        <p>{{ section.settings.about_text | default: 'PostureTru creates small moments of awareness that lead to lasting habits. Thoughtfully designed for people who spend long hours at a desk.' }}</p>
        <div class="footer-social-links" style="display: flex; gap: 16px; margin-top: 20px;">
          <a href="https://www.instagram.com/posture.tru" target="_blank" rel="noopener noreferrer" aria-label="PostureTru on Instagram, opens in a new tab" style="color: var(--color-white);">
            {% render 'icon-instagram' %}
          </a>
          <a href="https://www.tiktok.com/@posture.tru" target="_blank" rel="noopener noreferrer" aria-label="PostureTru on TikTok, opens in a new tab" style="color: var(--color-white);">
            {% render 'icon-tiktok' %}
          </a>
        </div>
      </div>

      <!-- Col 2: Explore -->
      <div class="footer-col">
        <h4>Explore</h4>
        <ul>
          <li><a href="/pages/about-us">About Us</a></li>
          <li><a href="/pages/about-us#mission">Our Mission</a></li>
          <li><a href="/pages/contact">Contact Us</a></li>
        </ul>
      </div>

      <!-- Col 3: Support -->
      <div class="footer-col">
        <h4>Support</h4>
        <ul>
          <li><a href="/pages/faq">FAQ</a></li>
          <li><a href="/policies/shipping-policy">Shipping</a></li>
          <li><a href="/policies/refund-policy">Returns</a></li>
          <li><a href="/pages/track-order">Track Order</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-flex">
      <span>&copy; {{ 'now' | date: "%Y" | default: "2026" }} PostureTru. All rights reserved.</span>
      <div class="footer-legal-links">
        <a href="/policies/terms-of-service">Terms of Service</a>
        <span style="opacity: 0.3;">|</span>
        <a href="/policies/privacy-policy">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "about_text",
      "label": "About Text",
      "default": "PostureTru is the smart posture corrector designed for remote workers. Stand straight. Feel better."
    }
  ]
}
{% endschema %}
