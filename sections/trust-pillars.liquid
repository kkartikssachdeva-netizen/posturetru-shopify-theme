<section id="PillarsSection" class="trust-pillars section-padding">
  <div class="container">
    <div class="section-header">
      <h2>{{ section.settings.title | default: 'Built for Long Hours at the Desk' }}</h2>
      <p>{{ section.settings.subtitle | default: "Whether you're working, studying, coding, or gaming, PostureTru helps you stay aware of your posture throughout the day." }}</p>
    </div>

    <div class="grid grid-4 pillars-grid">

      <div class="pillar-card">
        <div class="pillar-title-row">
          <span class="pillar-emoji">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2 12 6 4 10 20 14 8 18 14 22 12"></polyline></svg>
          </span>
          <h3>{{ section.settings.pillar_1_title | default: 'Gentle Vibration. Real Awareness.' }}</h3>
        </div>
        <p>{{ section.settings.pillar_1_text | default: 'The moment you begin to slouch, PostureTru delivers a gentle vibration reminder. No apps. No distractions. Just real time posture awareness.' }}</p>
      </div>

      <div class="pillar-card">
        <div class="pillar-title-row">
          <span class="pillar-emoji">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="17 1 21 5 17 9"></polyline><path d="M3 11V9a4 4 0 0 1 4-4h14"></path><polyline points="7 23 3 19 7 15"></polyline><path d="M21 13v2a4 4 0 0 1-4 4H3"></path></svg>
          </span>
          <h3>{{ section.settings.pillar_2_title | default: 'Build Better Habits' }}</h3>
        </div>
        <p>{{ section.settings.pillar_2_text | default: 'Better posture starts with awareness. PostureTru provides immediate feedback when your posture begins to slip, helping you stay mindful throughout the day.' }}</p>
      </div>

      <div class="pillar-card">
        <div class="pillar-title-row">
          <span class="pillar-emoji">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
          </span>
          <h3>{{ section.settings.pillar_3_title | default: 'Comfortable for Daily Wear' }}</h3>
        </div>
        <p>{{ section.settings.pillar_3_text | default: 'Lightweight and skin friendly, PostureTru sits comfortably against your upper back and can be worn discreetly under most clothing.' }}</p>
      </div>

      <div class="pillar-card">
        <div class="pillar-title-row">
          <span class="pillar-emoji">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </span>
          <h3>{{ section.settings.pillar_4_title | default: 'Try It Risk Free' }}</h3>
        </div>
        <p>{{ section.settings.pillar_4_text | default: "Backed by our 30 Day Satisfaction Guarantee. If PostureTru isn't the right fit for you, contact us and we'll work to make it right." }}</p>
      </div>

    </div>
  </div>
</section>

<style>
.pillars-grid {
  align-items: stretch;
}

.pillar-card {
  display: flex;
  flex-direction: column;
  padding: 32px 28px;
}

.pillar-title-row {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  margin-bottom: 14px;
}

.pillar-title-row .pillar-emoji {
  flex-shrink: 0;
  line-height: 1;
  display: flex;
  align-items: center;
  padding-top: 2px;
  color: var(--color-primary);
}

.pillar-title-row h3 {
  margin: 0;
  font-size: 14px;
  font-weight: 600;
  line-height: 1.3;
  letter-spacing: -0.01em;
  color: var(--color-primary);
}

.pillar-card > p {
  font-size: 13px;
  line-height: 1.65;
  color: var(--color-text-secondary);
  margin: 0;
  flex: 1;
}

@media (max-width: 768px) {
  #PillarsSection .section-header h2 {
    font-size: clamp(24px, 3vw, 38px);
  }
  .pillar-card {
    padding: 28px 24px;
  }
  .pillar-title-row h3 {
    font-size: 15px;
  }
  .pillar-card > p {
    font-size: 14px;
  }
}
</style>

