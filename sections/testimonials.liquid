<section class="testimonials section-padding" style="border-top: 1px solid var(--color-border); background-color: var(--color-bg);">
  <div class="container">
    <div class="section-header">
      <h2>{{ section.settings.title | default: 'Trusted by Remote Workers' }}</h2>
      
      <!-- Stars summary -->
      <div class="stars-summary">
        <div class="star-rating">
          {% for i in (1..5) %}
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          {% endfor %}
        </div>
        <span class="stars-summary-text">{{ section.settings.rating_label | default: '4.9/5 stars based on 1,200+ reviews' }}</span>
      </div>
    </div>

    <!-- Before / After Image Showcase -->
    <div style="display:flex; gap:24px; justify-content:center; margin-bottom:60px; flex-wrap:wrap;">
      
      <!-- Image 1: Before -->
      <div style="flex:1; min-width:260px; max-width:420px; text-align:center;">
        <div style="border-radius:16px; overflow:hidden; box-shadow:0 12px 40px rgba(27,73,101,0.12);">
          <img 
            src="https://cdn.shopify.com/s/files/1/0839/9274/0080/files/frame1_slouched.jpg?v=1780984466" 
            alt="Before PostureTru" 
            style="width:100%; height:auto; display:block;">
        </div>
        <div style="margin-top:14px;">
          <span style="display:inline-block; background:#FFF0EE; color:#E74C3C; font-size:12px; font-weight:700; padding:4px 14px; border-radius:20px; letter-spacing:0.08em; text-transform:uppercase;">Before</span>
          <p style="margin-top:8px; font-size:14px; color:#666;">Slouched, tired, back aching by noon</p>
        </div>
      </div>

      <!-- Divider arrow -->
      <div style="display:flex; align-items:center; justify-content:center; font-size:32px; color:#1B4965; flex-shrink:0;">
        →
      </div>

      <!-- Image 4: After -->
      <div style="flex:1; min-width:260px; max-width:420px; text-align:center;">
        <div style="border-radius:16px; overflow:hidden; box-shadow:0 12px 40px rgba(95,184,120,0.2);">
          <img 
            src="https://cdn.shopify.com/s/files/1/0839/9274/0080/files/frame4_upright.jpg?v=1780984466" 
            alt="After PostureTru" 
            style="width:100%; height:auto; display:block;">
        </div>
        <div style="margin-top:14px;">
          <span style="display:inline-block; background:#EDFAF3; color:#5FB878; font-size:12px; font-weight:700; padding:4px 14px; border-radius:20px; letter-spacing:0.08em; text-transform:uppercase;">After PostureTru</span>
          <p style="margin-top:8px; font-size:14px; color:#666;">Upright, confident, pain-free all day</p>
        </div>
      </div>

    </div>

    <!-- Testimonial Cards -->
    <div class="grid grid-3">
      <!-- Card 1 -->
      <div class="testimonial-card">
        <div>
          <div class="star-rating" style="margin-bottom: 15px; font-size:14px;">
            {% for i in (1..5) %}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            {% endfor %}
          </div>
          <p class="testimonial-quote">"I've been using PostureTru for 2 weeks and the difference is night and day. My back pain is gone, and I feel more energized at my desk. Best investment in my health I've made."</p>
        </div>
        <span class="testimonial-author">— Sarah M., Marketing Manager</span>
      </div>
      <!-- Card 2 -->
      <div class="testimonial-card">
        <div>
          <div class="star-rating" style="margin-bottom: 15px;">
            {% for i in (1..5) %}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            {% endfor %}
          </div>
          <p class="testimonial-quote">"As someone who works from home, PostureTru has been a game-changer. The vibration feedback actually trains your body to maintain better posture. Highly recommend."</p>
        </div>
        <span class="testimonial-author">— James T., Software Engineer</span>
      </div>
      <!-- Card 3 -->
      <div class="testimonial-card">
        <div>
          <div class="star-rating" style="margin-bottom: 15px;">
            {% for i in (1..5) %}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            {% endfor %}
          </div>
          <p class="testimonial-quote">"Quality is exceptional. The materials are comfortable, the fit is perfect, and it actually works. Worth every penny."</p>
        </div>
        <span class="testimonial-author">— Lisa K., Consultant</span>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Trusted by Remote Workers"
    },
    {
      "type": "text",
      "id": "rating_label",
      "label": "Rating Subtext",
      "default": "4.9/5 stars based on 1,200+ reviews"
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "category": "Text"
    }
  ]
}
{% endschema %}