<section class="testimonials section-padding" style="border-top: 1px solid var(--color-border); background-color: var(--color-bg);">
  <div class="container">
    <div class="section-header">
      <h2>{{ section.settings.title | default: 'Trusted by Remote Workers' }}</h2>
      
      <!-- Stars summary -->
      <div class="stars-summary">
        <div class="star-rating">
          {% for i in (1..5) %}
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          {% endfor %}
        </div>
        <span class="stars-summary-text">{{ section.settings.rating_label | default: '' }}</span>
      </div>
    </div>

    <div class="grid grid-3">
      <!-- Card 1 -->
      <div class="testimonial-card">
        <div>
          <div class="star-rating" style="margin-bottom: 15px; font-size:14px;">
            {% for i in (1..5) %}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            {% endfor %}
          </div>
          <p class="testimonial-quote">"I didn't expect to notice much in the first week, but I caught myself sitting up straight without thinking about it. That's exactly what I was hoping for."</p>
        </div>
        <span class="testimonial-author">— Sarah M., Marketing Manager</span>
      </div>
      <!-- Card 2 -->
      <div class="testimonial-card">
        <div>
          <div class="star-rating" style="margin-bottom: 15px;">
            {% for i in (1..5) %}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            {% endfor %}
          </div>
          <p class="testimonial-quote">"The vibration is subtle enough that it doesn't break your focus, but noticeable enough that you actually respond to it. Works exactly as described."</p>
        </div>
        <span class="testimonial-author">— James T., Software Engineer</span>
      </div>
      <!-- Card 3 -->
      <div class="testimonial-card">
        <div>
          <div class="star-rating" style="margin-bottom: 15px;">
            {% for i in (1..5) %}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            {% endfor %}
          </div>
          <p class="testimonial-quote">"Wore it through a full day of back-to-back calls. Comfortable, discreet, and I was noticeably more upright by the afternoon. Good product."</p>
        </div>
        <span class="testimonial-author">— Lisa K., Consultant</span>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Trusted by Remote Workers"
    },
    {
      "type": "text",
      "id": "rating_label",
      "label": "Rating Subtext",
      "default": "4.9/5 stars based on 1,200+ reviews"
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "category": "Text"
    }
  ]
}
{% endschema %}