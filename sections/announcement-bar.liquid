{% if section.settings.enable_bar %}
<div id="announcementBar" class="announcement-bar" role="region" aria-live="polite">
  <div class="announcement-message" id="announcementMessage">
    🔥 Only 15 Black Units Left . Grab Yours Before They're Gone
  </div>
</div>

<style>
  .announcement-bar {
    width: 100%;
    height: 36px;
    background: linear-gradient(135deg, #1B4965, #0D6E6E);
    animation: gradientShift 8s ease infinite;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @keyframes gradientShift {
    0% {
      background: linear-gradient(135deg, #1B4965, #0D6E6E);
    }
    50% {
      background: linear-gradient(135deg, #0D6E6E, #1B4965);
    }
    100% {
      background: linear-gradient(135deg, #1B4965, #0D6E6E);
    }
  }

  .announcement-message {
    color: white;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-align: center;
    animation: fadeInOut 4s ease-in-out infinite;
    white-space: nowrap;
    padding: 0 20px;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @keyframes fadeInOut {
    0% {
      opacity: 0;
    }
    5% {
      opacity: 1;
    }
    33.33% {
      opacity: 1;
    }
    38.33% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .announcement-bar {
      height: 34px;
    }

    .announcement-message {
      font-size: 11px;
    }
  }

  @media (max-width: 480px) {
    .announcement-bar {
      height: 32px;
    }

    .announcement-message {
      font-size: 10px;
      padding: 0 16px;
    }
  }
</style>

<script>
  (function() {
    const messages = [
      "🔥 Only 15 Black Units Left . Grab Yours Before They're Gone",
      "⚡ 50% OFF Today Only . Free Shipping to US, Canada & Australia",
      "💎 30 Day Money Back Guarantee"
    ];

    const messageEl = document.getElementById('announcementMessage');

    let currentIndex = 0;
    setInterval(function() {
      currentIndex = (currentIndex + 1) % messages.length;
      messageEl.textContent = messages[currentIndex];
    }, 4000);
  })();
</script>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_bar",
      "label": "Enable announcement bar",
      "default": true
    }
  ]
}
{% endschema %}
