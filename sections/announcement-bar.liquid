{% if section.settings.enable_bar %}
<div id="announcementBar" class="announcement-bar" role="region" aria-live="polite">
  <div class="announcement-message" id="announcementMessage">
    🔥 50% OFF Today <span style="text-decoration: line-through; text-decoration-color: #E74C3C; text-decoration-thickness: 1.5px;">$79.99</span> $39.99
  </div>
</div>

<style>
  .announcement-bar {
    width: 100%;
    height: 36px;
    background: linear-gradient(135deg, #1B4965, #0D6E6E);
    animation: gradientShift 8s ease infinite;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @keyframes gradientShift {
    0% {
      background: linear-gradient(135deg, #1B4965, #0D6E6E);
    }
    50% {
      background: linear-gradient(135deg, #0D6E6E, #1B4965);
    }
    100% {
      background: linear-gradient(135deg, #1B4965, #0D6E6E);
    }
  }

  .announcement-message {
    color: white;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-align: center;
    animation: slideMessage 4s ease-in-out infinite;
    white-space: nowrap;
    padding: 0 20px;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @keyframes slideMessage {
    0% {
      transform: translateX(100%);
    }
    15% {
      transform: translateX(0);
    }
    85% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-100%);
    }
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .announcement-bar {
      height: 34px;
    }

    .announcement-message {
      font-size: 11px;
    }
  }

  @media (max-width: 480px) {
    .announcement-bar {
      height: 32px;
    }

    .announcement-message {
      font-size: 10px;
      padding: 0 16px;
    }
  }
</style>

<script>
  (function() {
    const messages = [
      "🔥 50% OFF Today <span style=\"text-decoration: line-through; text-decoration-color: #E74C3C; text-decoration-thickness: 1.5px;\">$79.99</span> $39.99",

      "🚚 Free Shipping to USA, Canada & Australia",
      "✅ 100% Satisfaction Guaranteed"
    ];

    const messageEl = document.getElementById('announcementMessage');

    let currentIndex = 0;
    setInterval(function() {
      currentIndex = (currentIndex + 1) % messages.length;
      messageEl.innerHTML = messages[currentIndex];
    }, 4000);
  })();
</script>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_bar",
      "label": "Enable announcement bar",
      "default": true
    }
  ]
}
{% endschema %}
