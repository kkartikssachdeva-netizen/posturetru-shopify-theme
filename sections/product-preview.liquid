<section class="product-preview section-padding" id="productPreviewSection">
  <div class="container grid grid-2" style="align-items: center;">

    <!-- Image Column: scroll-driven transition -->
    <div class="product-preview-img-container" style="position:relative; border-radius:20px; overflow:hidden; box-shadow:0 20px 60px rgba(27,73,101,0.15); padding:0; overflow:hidden; min-height:400px;">

      <img
        src="https://cdn.shopify.com/s/files/1/0839/9274/0080/files/Product_Preview.jpg?v=1781159941"
        alt="Verta Smart Posture Corrector"
        style="width:100%; height:100%; object-fit:cover; border-radius:var(--border-radius-lg); display:block;">

    </div>

    <!-- Text Column (unchanged) -->
    <div class="product-preview-content">
      <h2>Meet Verta</h2>
      <p class="product-preview-text">A lightweight posture awareness trainer designed for long hours at the desk. The moment you begin to slouch, Verta delivers a gentle vibration reminder to help you stay mindful of your posture throughout the day.</p>
      <p class="product-preview-text" style="margin-top:-16px;">Using real time posture detection, it recognizes when your posture begins to slip and provides quiet, consistent feedback. No straps. No restriction. Just a smarter way to build better posture habits over time.</p>

      <div style="margin-top: 24px;">
        <a href="{{ section.settings.cta_link | default: '/products/posturetru' }}" class="btn btn-primary">
          {{ section.settings.cta_text | default: 'Shop Now' }}
        </a>
      </div>
    </div>

  </div>
</section>

<style>
@media (max-width: 768px) {
  .product-preview {
    padding-top: 0;
    border-top: none;
  }
  .product-preview-img-container {
    width: 100vw !important;
    margin-left: calc(-50vw + 50%) !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    min-height: unset !important;
  }
  .product-preview-img-container img {
    border-radius: 0 !important;
    height: auto !important;
    width: 100% !important;
    object-fit: unset !important;
  }
  .product-preview-content > div:last-child {
    text-align: center;
  }
}
</style>

{% schema %}
{
  "name": "Product Preview",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "The Smart Posture Corrector"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Verta isn't a brace. It uses a high precision gyroscope chip to detect slouching in real time and delivers a gentle vibration reminder, training your body to self correct naturally."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    }
  ],
  "presets": [
    {
      "name": "Product Preview",
      "category": "Product"
    }
  ]
}
{% endschema %}