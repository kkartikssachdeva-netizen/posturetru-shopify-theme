<section class="product-preview section-padding" id="productPreviewSection" style="border-top: 1px solid var(--color-border);">
  <div class="container grid grid-2" style="align-items: center;">

    <!-- Image Column: scroll-driven transition -->
    <div class="product-preview-img-container" style="position:relative; border-radius:20px; overflow:hidden; box-shadow:0 20px 60px rgba(27,73,101,0.15);">

      <!-- Frame 1 -->
      <img
        id="ppFrame1"
        src="https://cdn.shopify.com/s/files/1/0839/9274/0080/files/frame1_slouched.jpg?v=1780984466"
        alt="PostureTru posture corrector"
        loading="eager"
        style="width:100%; height:auto; display:block; position:relative; z-index:2; transition:opacity 0.7s ease, transform 0.8s ease; transform:scale(1);">

      <!-- Frame 4 -->
      <img
        id="ppFrame4"
        src="https://cdn.shopify.com/s/files/1/0839/9274/0080/files/frame4_upright.jpg?v=1780984466"
        alt="PostureTru posture corrected"
        loading="lazy"
        style="width:100%; height:100%; display:block; position:absolute; top:0; left:0; z-index:1; opacity:0; transition:opacity 0.7s ease, transform 0.8s ease; transform:scale(1.03); object-fit:cover;">

    </div>

    <!-- Text Column (unchanged) -->
    <div class="product-preview-content">
      <h2>{{ section.settings.title | default: 'The Smart Posture Corrector' }}</h2>
      <p class="product-preview-text">
        {{ section.settings.description | default: "PostureTru isn't just a brace. It's your personal posture coach. Our smart magnetic posture belt combines the power of magnets with intelligent sensors to actively improve your body's muscle memory." }}
      </p>
      
      <ul class="product-preview-list">
        <li>10 therapeutic magnets for blood circulation</li>
        <li>Real-time vibration alerts when you slouch</li>
        <li>Adjustable sizing for men and women</li>
        <li>Invisible under clothing</li>
      </ul>
      
      <div style="margin-top: 10px;">
        <a href="{{ section.settings.cta_link | default: '/pages/shop' }}" class="btn btn-primary">
          {{ section.settings.cta_text | default: 'Shop Now' }}
        </a>
      </div>
    </div>

  </div>
</section>

<script>
(function () {
  var pre = new Image();
  pre.src = 'https://cdn.shopify.com/s/files/1/0839/9274/0080/files/frame4_upright.jpg?v=1780984466';

  document.addEventListener('DOMContentLoaded', function () {
    var section = document.getElementById('productPreviewSection');
    var f1 = document.getElementById('ppFrame1');
    var f4 = document.getElementById('ppFrame4');
    var state = 'before';
    var ticking = false;

    function update() {
      var rect = section.getBoundingClientRect();
      var progress = Math.min(Math.max((-rect.top + window.innerHeight * 0.3) / (section.offsetHeight * 0.5), 0), 1);

      if (progress >= 0.5 && state !== 'after') {
        state = 'after';
        f1.style.opacity = '0';
        f1.style.transform = 'scale(1.03)';
        f4.style.opacity = '1';
        f4.style.transform = 'scale(1)';
        f4.style.zIndex = '2';
        f1.style.zIndex = '1';
      } else if (progress < 0.5 && state !== 'before') {
        state = 'before';
        f1.style.opacity = '1';
        f1.style.transform = 'scale(1)';
        f4.style.opacity = '0';
        f4.style.transform = 'scale(1.03)';
        f4.style.zIndex = '1';
        f1.style.zIndex = '2';
      }
      ticking = false;
    }

    window.addEventListener('scroll', function () {
      if (!ticking) { requestAnimationFrame(update); ticking = true; }
    }, { passive: true });
  });
})();
</script>

{% schema %}
{
  "name": "Product Preview",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "The Smart Posture Corrector"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "PostureTru isn't just a brace. It's your personal posture coach. Our smart magnetic posture belt combines the power of magnets with intelligent sensors to actively improve your body's muscle memory."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    }
  ],
  "presets": [
    {
      "name": "Product Preview",
      "category": "Product"
    }
  ]
}
{% endschema %}