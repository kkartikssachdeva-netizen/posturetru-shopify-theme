<section class="product-preview section-padding" id="productPreviewSection" style="border-top: 1px solid var(--color-border);">
  <div class="container grid grid-2" style="align-items: center;">

    <!-- Image Column: scroll-driven transition -->
    <div class="product-preview-img-container" style="position:relative; border-radius:20px; overflow:hidden; box-shadow:0 20px 60px rgba(27,73,101,0.15); padding:0; overflow:hidden; min-height:400px;">

      <img
        src="https://cdn.shopify.com/s/files/1/0839/9274/0080/files/Product_Preview.jpg?v=1781159941"
        alt="PostureTru Smart Posture Corrector"
        style="width:100%; height:100%; object-fit:cover; border-radius:var(--border-radius-lg); display:block;">

    </div>

    <!-- Text Column (unchanged) -->
    <div class="product-preview-content">
      <h2>Meet PostureTru</h2>
      <p class="product-preview-text">A lightweight posture awareness trainer designed for long hours at the desk. The moment you begin to slouch, PostureTru delivers a gentle vibration reminder to help you stay mindful of your posture throughout the day.</p>
      <p class="product-preview-text" style="margin-top:-16px;">Using real-time posture detection, it recognizes when your posture begins to slip and provides quiet, consistent feedback. No straps. No restriction. Just a smarter way to build better posture habits over time.</p>

      <ul class="product-preview-list">
        <li>Detects slouching in real time</li>
        <li>Gentle vibration feedback encourages posture awareness</li>
        <li>Comfortable for all-day wear</li>
        <li>Discreet design fits under most clothing</li>
        <li>USB rechargeable with up to 7 days of battery life</li>
      </ul>
      
      <div style="margin-top: 10px;">
        <a href="{{ section.settings.cta_link | default: '/pages/shop' }}" class="btn btn-primary">
          {{ section.settings.cta_text | default: 'Shop Now' }}
        </a>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Product Preview",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "The Smart Posture Corrector"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "PostureTru isn't just a brace. It's your personal posture coach. Our smart magnetic posture belt combines the power of magnets with intelligent sensors to actively improve your body's muscle memory."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    }
  ],
  "presets": [
    {
      "name": "Product Preview",
      "category": "Product"
    }
  ]
}
{% endschema %}