<section class="about-hero" id="contactHeroSection">
  <div class="container">
    <h1 style="font-size: clamp(28px, 6vw, 48px); margin-bottom: 16px;"><span class="intro-word">Get</span>&nbsp;<span class="intro-word">in</span>&nbsp;<span class="intro-word">Touch</span></h1>
    <p class="entrance-fade" style="font-size: clamp(15px, 3.5vw, 18px); color: var(--color-text-secondary); max-width: 760px; margin: 0 auto;">
      <span class="contact-sub-line">Questions, feedback, or just want to say hello?</span> <span class="contact-sub-line">We would love to hear from you.</span>
    </p>
  </div>
</section>

<section class="section-padding">
  <div class="container contact-layout">
    <!-- Contact Info Block -->
    <div class="contact-info-block">
      <h3>Contact Information</h3>
      <p>Whether you have a question about delivery, returns, or how Verta works, our team is here and happy to help.</p>

      <div class="contact-methods">
        <!-- Method 1 -->
        <div class="contact-method-item">
          <div class="contact-method-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </div>
          <div class="contact-method-details">
            <h4>Customer Support Email</h4>
            <p>support@posturetru.com</p>
          </div>
        </div>

        <!-- Method 2 -->
        <div class="contact-method-item">
          <div class="contact-method-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <div class="contact-method-details">
            <h4>Response Time</h4>
            <p>We typically reply within 24 hours on business days.</p>
          </div>
        </div>

        <!-- Method 3 -->
        <div class="contact-method-item">
          <div class="contact-method-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
          </div>
          <div class="contact-method-details">
            <h4>Looking for a Quick Answer?</h4>
            <p>Many common questions are already answered on our <a href="/pages/faq" style="text-decoration: underline; color: var(--color-primary); font-weight:600;">FAQ page</a>. It is the fastest way to find what you need.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact Form Card -->
    <div class="contact-form-card">
      {%- form 'contact', id: 'contactForm' -%}
        {%- if form.posted_successfully? -%}
          <div class="form-success-msg" style="display: block;">
            Thank you for contacting PostureTru. We will reply within 24 hours.
          </div>
        {%- endif -%}

        <div class="form-group">
          <label for="ContactFormName">Full Name</label>
          <input type="text" id="ContactFormName" name="contact[name]" class="form-control" placeholder="John Doe" required>
        </div>

        <div class="form-group">
          <label for="ContactFormEmail">Email Address</label>
          <input type="email" id="ContactFormEmail" name="contact[email]" class="form-control" placeholder="john@example.com" required>
        </div>

        <div class="form-group">
          <label for="ContactFormSubject">Subject Concern</label>
          <select id="ContactFormSubject" name="contact[subject]" class="form-control" required style="-webkit-appearance: none; background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2224%22 height=%2224%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%237F8C8D%22 stroke-width=%222%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22><polyline points=%226 9 12 15 18 9%22></polyline></svg>'); background-repeat: no-repeat; background-position: right 16px center; background-size: 16px;">
            <option value="Question about product">Question about product</option>
            <option value="Order help">Order help</option>
            <option value="After sale support">After sale support</option>
            <option value="Feedback">Feedback</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div class="form-group" style="margin-bottom: 30px;">
          <label for="ContactFormMessage">Your Message</label>
          <textarea id="ContactFormMessage" name="contact[body]" class="form-control" placeholder="How can we assist you?" required></textarea>
        </div>

        <button type="submit" class="btn btn-primary btn-full">Send Message</button>
      {%- endform -%}
    </div>
  </div>
</section>

<style>
#contactHeroSection {
  position: relative;
  overflow: hidden;
  background-color: transparent;
}

#contactHeroSection::before {
  content: '';
  position: absolute;
  inset: -20px;
  background-image: url('https://cdn.shopify.com/s/files/1/0839/9274/0080/files/Contact.jpg?v=1782911964');
  background-size: cover;
  background-position: center;
  filter: blur(7px);
}

#contactHeroSection::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(240, 244, 248, 0.78);
}

#contactHeroSection .container {
  position: relative;
  z-index: 1;
}
</style>

<script>
(function(){
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  var section = document.getElementById('contactHeroSection');
  if (!section) return;
  var words = section.querySelectorAll('.intro-word');
  var fade = section.querySelector('.entrance-fade');
  var staggerBudget = 300;
  var stagger = words.length ? Math.min(32, staggerBudget / words.length) : 32;
  var wordTransition = 560;
  words.forEach(function(w){
    var dx = (Math.random() * 90 - 45).toFixed(0);
    var dy = (Math.random() * 70 - 35).toFixed(0);
    var rot = (Math.random() * 18 - 9).toFixed(1);
    w.style.transform = 'translate(' + dx + 'px,' + dy + 'px) rotate(' + rot + 'deg)';
  });
  void document.body.offsetHeight;
  words.forEach(function(w, i){
    var delay = i * stagger;
    w.style.transition = 'transform ' + wordTransition + 'ms cubic-bezier(0.16,1,0.3,1) ' + delay + 'ms, opacity 420ms ease-out ' + delay + 'ms';
    w.style.opacity = '1';
    w.style.transform = 'translate(0,0) rotate(0deg)';
  });
  var finishAt = words.length ? (words.length - 1) * stagger + wordTransition : 0;
  if (fade) {
    var fadeDelay = finishAt + 80;
    fade.style.transition = 'opacity 480ms ease-out ' + fadeDelay + 'ms, transform 480ms cubic-bezier(0.16,1,0.3,1) ' + fadeDelay + 'ms';
    fade.style.opacity = '1';
    fade.style.transform = 'translateY(0)';
  }
})();
</script>

{% schema %}
{
  "name": "Contact Details",
  "settings": []
}
{% endschema %}
