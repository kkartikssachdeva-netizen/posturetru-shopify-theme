<section class="section-padding product-hero-section">
  <div class="container product-template-grid">
    <!-- Gallery Column -->
    <div class="product-gallery">
      <div id="mainImageContainer" class="main-image-viewport">
        <img src="{{ product.featured_image | img_url: '800x800' }}"
             alt="{{ product.title }}"
             id="mainProductImage"
             style="width:100%; height:100%; object-fit:contain; border-radius:12px;">
      </div>
      
      <!-- Thumbnail Strip -->
      <div class="thumbnail-strip">
        {% for image in product.images limit:8 %}
        <button class="thumb-button {% if forloop.first %}active{% endif %}"
                data-image-url="{{ image | img_url: '800x800' }}"
                aria-label="Product image {{ forloop.index }}">
          <img src="{{ image | img_url: '200x200' }}" alt="{{ product.title }}">
        </button>
        {% endfor %}
      </div>
    </div>
    
    <!-- Info Column -->
    <div class="product-details">
<h1 class="product-title">{{ product.title | default: 'PostureTru Smart Posture Corrector' }}</h1>
      
      <div class="product-meta-row">
        <span style="font-size: 14px; font-weight: 500; color: var(--color-text-secondary);">SKU: {{ product.variants.first.sku }}</span>
      </div>
      
      <div class="product-pricing">
        <span class="price-compare" style="
          font-size: 22px;
          color: #999;
          text-decoration: line-through;
          text-decoration-color: #E74C3C;
          text-decoration-thickness: 2px;
          margin-right: 0;
        ">{{ product.compare_at_price | money }}</span>

        <span class="price-current" style="
          font-size: 28px;
          font-weight: 800;
          color: #1B4965;
          letter-spacing: -1px;
        ">{{ product.price | money }}</span>

        <div style="margin-top: 8px;">
          <span style="
            background: #E74C3C;
            color: white;
            font-size: 13px;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 20px;
            letter-spacing: 0.05em;
          ">SAVE 50%</span>
        </div>
      </div>
      
      <div class="product-short-description">
        {{ section.settings.short_description }}
      </div>
      
      <!-- Interactive ATC Box -->
      <div class="atc-section">
        <!-- Quantity Selector and CTA -->
        <div class="quantity-row">
          <div class="quantity-selector">
            <button id="qtyMinus" class="qty-btn" aria-label="Decrease Quantity">-</button>
            <input type="text" id="productQty" class="qty-input" value="1" readonly aria-label="Product Quantity">
            <button id="qtyPlus" class="qty-btn" aria-label="Increase Quantity">+</button>
          </div>
          
          {% form 'product', product, id: 'product-form-main' %}
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            <input type="hidden" name="quantity" value="1">
            <button type="submit" class="btn btn-secondary btn-full" style="flex: 1; margin:0;">
              Add to Cart
            </button>
          {% endform %}
        </div>
        
        <div class="payment-buttons-wrap">
          <div class="payment-divider"><span>or</span></div>
          {% form 'product', product, id: 'product-form-payment' %}
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            <input type="hidden" name="quantity" value="1">
            {{ form | payment_button }}
          {% endform %}
        </div>

        <div class="shipping-promo-box">
          {% render 'icon-truck' %}
          <div class="shipping-promo-text">
            <strong>FREE Tracked Shipping</strong> to Canada, Australia, UK & NZ. Delivery in 6–14 business days.
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.thumb-button').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('mainProductImage').src = btn.dataset.imageUrl;
      document.querySelectorAll('.thumb-button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });
</script>

{% schema %}
{
  "name": "Product Details",
  "settings": [
    {
      "type": "textarea",
      "id": "short_description",
      "label": "Short Description",
      "default": "PostureTru is a posture awareness trainer designed to help you build better posture through gentle, real time feedback. The moment you begin to slouch, it delivers a subtle vibration reminder. Straighten your posture and the vibration stops."
    }
  ]
}
{% endschema %}
