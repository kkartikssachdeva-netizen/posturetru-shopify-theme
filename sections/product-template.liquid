<section class="section-padding product-hero-section" style="padding-bottom: 0;">
  <div class="container product-template-grid">
    <!-- Gallery Column -->
    <div class="product-gallery">
      <div id="mainImageContainer" class="main-image-viewport entrance-fade-img">
        <img src="{{ product.featured_image | img_url: '800x800' }}"
             alt="{{ product.title }}"
             id="mainProductImage"
             style="width:100%; height:100%; object-fit:contain; border-radius:12px;">
      </div>
      
      <!-- Thumbnail Strip -->
      <div class="thumbnail-strip">
        {% for image in product.images limit:8 %}
        <button class="thumb-button {% if forloop.first %}active{% endif %}"
                data-image-url="{{ image | img_url: '800x800' }}"
                aria-label="Product image {{ forloop.index }}">
          <img src="{{ image | img_url: '200x200' }}" alt="{{ product.title }}">
        </button>
        {% endfor %}
      </div>
    </div>
    
    <!-- Info Column -->
    <div class="product-details">
<h1 class="product-title">{% assign pt_title_words = product.title | default: 'PostureTru™ Smart Posture Corrector' | split: ' ' %}{% for word in pt_title_words %}<span class="intro-word">{{ word }}</span>{% unless forloop.last %}&nbsp;{% endunless %}{% endfor %}</h1>
      
      
      <div class="product-pricing">
        <span class="price-compare" style="
          font-size: 22px;
          color: #999;
          text-decoration: line-through;
          text-decoration-color: #E74C3C;
          text-decoration-thickness: 2px;
          margin-right: 0;
        ">{{ product.compare_at_price | money }}</span>

        <span class="price-current" style="
          font-size: 28px;
          font-weight: 800;
          color: #1B4965;
          letter-spacing: -1px;
        ">{{ product.price | money }}</span>

        <div style="margin-top: 8px;">
          <span style="
            background: #E74C3C;
            color: white;
            font-size: 13px;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 20px;
            letter-spacing: 0.05em;
          ">SAVE 50%</span>
        </div>
      </div>
      
      <div class="mini-trust-row">
        <div class="mini-trust-badge">
          {% render 'icon-shield' %}
          <span>30 Day Returns</span>
        </div>
        <div class="mini-trust-badge">
          {% render 'icon-truck' %}
          <span>Free Shipping</span>
        </div>
        <div class="mini-trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          <span>Secure Checkout</span>
        </div>
      </div>

      <div class="product-short-description entrance-fade">
        {{ section.settings.short_description }}
      </div>
      
      <!-- Interactive ATC Box -->
      <div class="atc-section">
        <!-- Quantity Selector and CTA -->
        <div class="quantity-row">
          <div class="quantity-selector">
            <button id="qtyMinus" class="qty-btn" aria-label="Decrease Quantity">-</button>
            <input type="text" id="productQty" class="qty-input" value="1" readonly aria-label="Product Quantity">
            <button id="qtyPlus" class="qty-btn" aria-label="Increase Quantity">+</button>
          </div>
          
          {% form 'product', product, id: 'product-form-main' %}
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            <input type="hidden" name="quantity" value="1">
            <button type="submit" class="btn btn-secondary btn-full" style="flex: 1; margin:0;">
              Add to Cart
            </button>
          {% endform %}
        </div>
        
        <div class="payment-buttons-wrap">
          {% form 'product', product, id: 'product-form-payment' %}
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            <input type="hidden" name="quantity" value="1">
            {{ form | payment_button }}
          {% endform %}
        </div>

        <div class="shipping-promo-box">
          {% render 'icon-truck' %}
          <div class="shipping-promo-text">
            <strong>FREE Tracked Shipping</strong> to Canada, Australia, UK & NZ. Delivery in 6 to 14 business days.
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.thumb-button').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('mainProductImage').src = btn.dataset.imageUrl;
      document.querySelectorAll('.thumb-button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });
</script>

<script>
(function(){
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  var words = document.querySelectorAll('.product-title .intro-word');
  var shortDesc = document.querySelector('.product-short-description');
  var img = document.getElementById('mainImageContainer');
  var staggerBudget = 300;
  var stagger = words.length ? Math.min(32, staggerBudget / words.length) : 32;
  var wordTransition = 560;

  words.forEach(function(w){
    var dx = (Math.random() * 90 - 45).toFixed(0);
    var dy = (Math.random() * 70 - 35).toFixed(0);
    var rot = (Math.random() * 18 - 9).toFixed(1);
    w.style.transform = 'translate(' + dx + 'px,' + dy + 'px) rotate(' + rot + 'deg)';
  });
  void document.body.offsetHeight;
  words.forEach(function(w, i){
    var delay = i * stagger;
    w.style.transition = 'transform ' + wordTransition + 'ms cubic-bezier(0.16,1,0.3,1) ' + delay + 'ms, opacity 420ms ease-out ' + delay + 'ms';
    w.style.opacity = '1';
    w.style.transform = 'translate(0,0) rotate(0deg)';
  });

  var wordsFinishAt = words.length ? (words.length - 1) * stagger + wordTransition : 0;

  if (shortDesc) {
    var descDelay = wordsFinishAt + 80;
    shortDesc.style.transition = 'opacity 480ms ease-out ' + descDelay + 'ms, transform 480ms cubic-bezier(0.16,1,0.3,1) ' + descDelay + 'ms';
    shortDesc.style.opacity = '1';
    shortDesc.style.transform = 'translateY(0)';
  }

  if (img) {
    img.style.transition = 'opacity 600ms ease-out 80ms, transform 600ms cubic-bezier(0.16,1,0.3,1) 80ms';
    img.style.opacity = '1';
    img.style.transform = 'translateY(0)';
  }
})();
</script>

{% schema %}
{
  "name": "Product Details",
  "settings": [
    {
      "type": "textarea",
      "id": "short_description",
      "label": "Short Description",
      "default": "Verta is built around a simple idea: most slouching is not a posture problem, it is an attention problem. The moment your attention drifts and your posture follows, Verta meets you with a gentle vibration, a quiet nudge back to how you actually want to sit. Straighten up, and the vibration stops. No straps, no restriction, just real time feedback that helps awareness become habit."
    }
  ]
}
{% endschema %}
