<section id="productBenefitsSection" class="section-padding" style="background-color: var(--color-bg);">
  <div class="container">
    <div class="section-header">
      <h2 style="white-space: nowrap; font-size: clamp(12px, 4vw, 38px);">{% assign pb_words = section.settings.title | default: 'Better Posture Begins With Awareness' | split: ' ' %}{% for word in pb_words %}<span class="intro-word">{{ word }}</span>{% unless forloop.last %}&nbsp;{% endunless %}{% endfor %}</h2>
      <p class="entrance-fade">{{ section.settings.subtitle | default: "Verta is not designed to force perfect posture. It helps you notice the moment you begin to slouch, making it easier to return to better posture throughout your day. Over time, those small moments of awareness become lasting habits." }}</p>
    </div>

    <div class="grid grid-4">
      <!-- Benefit 1 -->
      <div class="benefit-card">
        <h3>Notice the Moment</h3>
        <p>Verta gently vibrates the instant you begin to slouch, helping you recognize poor posture before it becomes your default.</p>
      </div>

      <!-- Benefit 2 -->
      <div class="benefit-card">
        <h3>Build Better Habits</h3>
        <p>Every reminder is an opportunity to reset. With consistent awareness, better posture becomes something that feels natural instead of something you have to remember.</p>
      </div>

      <!-- Benefit 3 -->
      <div class="benefit-card">
        <h3>Designed for Everyday Comfort</h3>
        <p>Crafted from soft, food-grade silicone and weighing just 70 grams, Verta sits comfortably beneath your clothing so you can wear it throughout your day with ease.</p>
      </div>

      <!-- Benefit 4 -->
      <div class="benefit-card">
        <h3>Fits Into Your Routine</h3>
        <p>Whether you are working, studying, commuting, or gaming, Verta quietly works in the background with no app to monitor and no routine to follow.</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Benefits",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Better Posture Begins With Awareness"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Verta is not designed to force perfect posture. It helps you notice the moment you begin to slouch, making it easier to return to better posture throughout your day. Over time, those small moments of awareness become lasting habits."
    }
  ]
}
{% endschema %}
