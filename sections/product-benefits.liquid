<section class="section-padding" style="background-color: var(--color-bg);">
  <div class="container">
    <div class="section-header">
      <h2>{{ section.settings.title | default: 'Daily Benefits You Will Feel' }}</h2>
      <p>{{ section.settings.subtitle | default: 'Improve your comfort, vitality, and productivity with PostureTru.' }}</p>
    </div>
    
    <div class="grid grid-4">
      <!-- Benefit 1 -->
      <div class="benefit-card">
        <div class="benefit-num">01</div>
        <h3>Pain Relief</h3>
        <p>Say goodbye to end-of-day back pain, neck stiffness, and shoulder tension. Users report relief within 3-7 days.</p>
      </div>

      <!-- Benefit 2 -->
      <div class="benefit-card">
        <div class="benefit-num">02</div>
        <h3>Better Energy</h3>
        <p>Proper posture improves lung breathing capacity and blood flow. Feel more alert and energized throughout your WFH shift.</p>
      </div>

      <!-- Benefit 3 -->
      <div class="benefit-card">
        <div class="benefit-num">03</div>
        <h3>More Confidence</h3>
        <p>Stand taller. Feel better. Look more professional. Real-time posture changes instantly boost your mood and self-image.</p>
      </div>

      <!-- Benefit 4 -->
      <div class="benefit-card">
        <div class="benefit-num">04</div>
        <h3>Long-Term Health</h3>
        <p>Prevent chronic posture deformities before they set in. PostureTru trains muscle memory for natural, lifelong alignment.</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Benefits",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Daily Benefits You Will Feel"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Improve your comfort, vitality, and productivity with PostureTru."
    }
  ]
}
{% endschema %}
