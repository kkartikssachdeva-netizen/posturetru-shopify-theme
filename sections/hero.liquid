<section class="hero" id="heroSection">
  <div class="container grid grid-2" style="align-items: center;">
    
    <!-- Left: Text Content (unchanged) -->
    <div class="hero-content">
      <span class="hero-tagline">{{ section.settings.tagline | default: 'Stand Straight. Feel Better.' }}</span>
      <h1 class="hero-title">{{ section.settings.title | default: 'Your Posture Shapes Your Life' }}</h1>
      <p class="hero-subheading">{{ section.settings.subheading | default: 'Professional-grade posture correction for remote workers who refuse to compromise on health' }}</p>
      <div style="display: flex; gap: 16px; align-items: center; flex-wrap: wrap;">
        <a href="{{ section.settings.cta_link | default: '/pages/shop' }}" class="btn btn-primary">
          {{ section.settings.cta_text | default: 'Shop PostureTru' }}
        </a>
        <a href="#PillarsSection" class="btn btn-outline">Learn More</a>
      </div>
    </div>

    <!-- Right: Scroll-driven image showcase -->
    <div class="hero-img-container" style="position:relative;">
      
      <!-- Image wrapper -->
      <div class="hero-img-mockup" style="position:relative; border-radius:24px; overflow:hidden; box-shadow:0 30px 80px rgba(27,73,101,0.2);">
        
        <!-- Frame 1: Slouched (visible on load) -->
        <img 
          id="heroFrame1"
          src="https://cdn.shopify.com/s/files/1/0839/9274/0080/files/frame1_slouched.jpg?v=1780984466"
          alt="PostureTru posture corrector in use"
          style="width:100%; display:block; position:relative; z-index:2; transition: opacity 0.6s ease, transform 0.8s ease; transform-origin: center center;"
          loading="eager">

        <!-- Frame 4: Upright (hidden, fades in on scroll) -->
        <img 
          id="heroFrame4"
          src="https://cdn.shopify.com/s/files/1/0839/9274/0080/files/frame4_upright.jpg?v=1780984466"
          alt="PostureTru posture corrected"
          style="width:100%; display:block; position:absolute; top:0; left:0; z-index:1; opacity:0; transition: opacity 0.6s ease, transform 0.8s ease; transform: scale(1.03);"
          loading="lazy">

      </div>

      <!-- Trust badge (kept from original) -->
      <div class="hero-trust-badge">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#5FB878" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        <span>Recommended by Ergonomists</span>
      </div>

    </div>
  </div>
</section>

<style>
  /* Ensure image container maintains aspect ratio */
  .hero-img-mockup {
    aspect-ratio: 4/5;
    background: #F0F4F8;
  }
  .hero-img-mockup img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (max-width: 768px) {
    #heroSection .grid-2 {
      display: flex;
      flex-direction: column-reverse;
      gap: 32px;
    }
    .hero-img-mockup {
      aspect-ratio: 4/3;
    }
  }
</style>

<script>
(function() {
  /* Preload frame 4 immediately for instant transition */
  var preload = new Image();
  preload.src = 'https://cdn.shopify.com/s/files/1/0839/9274/0080/files/frame4_upright.jpg?v=1780984466';

  document.addEventListener('DOMContentLoaded', function() {
    var hero = document.getElementById('heroSection');
    var frame1 = document.getElementById('heroFrame1');
    var frame4 = document.getElementById('heroFrame4');
    var ticking = false;
    var transitioned = false;

    function updateScroll() {
      var rect = hero.getBoundingClientRect();
      var heroHeight = hero.offsetHeight;
      
      /* Progress: 0 = top of hero, 1 = bottom of hero */
      var progress = Math.min(Math.max(-rect.top / (heroHeight * 0.6), 0), 1);

      if (progress > 0.3 && !transitioned) {
        /* Fade out frame 1, fade in frame 4 */
        transitioned = true;
        frame1.style.opacity = '0';
        frame1.style.transform = 'scale(1.03)';
        frame4.style.opacity = '1';
        frame4.style.transform = 'scale(1)';
        frame4.style.zIndex = '2';
        frame1.style.zIndex = '1';
      } else if (progress <= 0.3 && transitioned) {
        /* Reverse when scrolling back up */
        transitioned = false;
        frame1.style.opacity = '1';
        frame1.style.transform = 'scale(1)';
        frame4.style.opacity = '0';
        frame4.style.transform = 'scale(1.03)';
        frame4.style.zIndex = '1';
        frame1.style.zIndex = '2';
      }

      ticking = false;
    }

    window.addEventListener('scroll', function() {
      if (!ticking) {
        requestAnimationFrame(updateScroll);
        ticking = true;
      }
    }, { passive: true });
  });
})();
</script>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Stand Straight. Feel Better."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Your Posture Shapes Your Life"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Professional-grade posture correction for remote workers who refuse to compromise on health"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Shop PostureTru"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Hero"
    }
  ]
}
{% endschema %}