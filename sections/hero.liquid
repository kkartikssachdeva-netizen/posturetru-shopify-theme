<div class="hero-wrapper" id="heroWrapper">

  <!-- FLOATING HEADER -->
  <div class="hero-header">
    <div class="container flex-between" style="width: 100%;">

      <button id="menuToggleBtn" class="menu-toggle" aria-label="Open Navigation Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>

      <a href="/" class="logo logo--image hero-logo" aria-label="PostureTru home">
        <img
          src="https://cdn.shopify.com/s/files/1/0839/9274/0080/files/PostureTru_logo.png?v=1782105959"
          alt="PostureTru"
          class="logo-img"
          width="200"
          height="48"
          loading="eager"
        >
      </a>

      <nav class="nav-menu" aria-label="Main Navigation">
        <a href="/products/posturetru" class="nav-link hero-nav-link">Shop</a>
        <a href="/pages/about-us" class="nav-link hero-nav-link {% if request.path contains '/about-us' %}active{% endif %}">About</a>
        <a href="/pages/faq" class="nav-link hero-nav-link {% if request.path contains '/faq' %}active{% endif %}">FAQ</a>
        <a href="/pages/contact" class="nav-link hero-nav-link {% if request.path contains '/contact' %}active{% endif %}">Contact</a>
      </nav>

      <div class="header-icons">
        <button id="cartIconBtn" class="cart-icon-btn hero-cart-btn" aria-label="Open Shopping Cart">
          {% render 'icon-cart' %}
          <span id="cartBadgeCount" class="cart-badge" style="display: none;">0</span>
        </button>
      </div>

    </div>
  </div>

  <!-- HERO CONTENT -->
  <section class="hero-section" id="heroSection">
    <div class="container hero-grid">

      <div class="hero-content">
        <span class="hero-tagline">{% assign hero_tagline_words = section.settings.tagline | default: 'Stand Straight. Feel Better.' | split: ' ' %}{% for word in hero_tagline_words %}<span class="intro-word">{{ word }}</span>{% unless forloop.last %}&nbsp;{% endunless %}{% endfor %}</span>
        <h1 class="hero-title">{% assign hero_title_words = section.settings.title | default: 'Your Posture Shapes Your Life' | split: ' ' %}{% for word in hero_title_words %}<span class="intro-word">{{ word }}</span>{% unless forloop.last %}&nbsp;{% endunless %}{% endfor %}</h1>
        <p class="hero-subheading">{{ section.settings.subheading | default: 'Professional-grade posture correction for remote workers who refuse to compromise on health' }}</p>
        <div class="hero-cta-row" id="heroCtaRow">
          <a href="{{ section.settings.cta_link | default: '/products/posturetru' }}" class="btn btn-primary">
            {{ section.settings.cta_text | default: 'Shop Verta' }}
          </a>
        </div>
      </div>

      <div class="hero-img-container">
        <div class="hero-img-mockup">
          <img
            src="https://cdn.shopify.com/s/files/1/0839/9274/0080/files/Hero.jpg?v=1781111084"
            alt="Verta Smart Posture Corrector"
            style="width:100%; max-width:500px; height:auto; border-radius:16px; display:block;">
        </div>
      </div>

    </div>
  </section>

</div>

<!-- MOBILE NAV DRAWER -->
<div id="mobileNavDrawer" class="mobile-nav-drawer" aria-modal="true" role="dialog">
  <div class="mobile-nav-header">
    <a href="/" class="logo logo--image" aria-label="PostureTru home">
      <img
        src="https://cdn.shopify.com/s/files/1/0839/9274/0080/files/PostureTru_logo.png?v=1782105959"
        alt="PostureTru"
        class="logo-img logo-img--drawer"
        width="160"
        height="38"
        loading="lazy"
      >
    </a>
    <button id="closeMenuBtn" class="close-drawer-btn" aria-label="Close Navigation Menu">&times;</button>
  </div>
  <nav class="mobile-nav-links" aria-label="Mobile Navigation">
    <a href="/products/posturetru" class="mobile-nav-link">Shop</a>
    <a href="/pages/about-us" class="mobile-nav-link {% if request.path contains '/about-us' %}active{% endif %}">About</a>
    <a href="/pages/faq" class="mobile-nav-link {% if request.path contains '/faq' %}active{% endif %}">FAQ</a>
    <a href="/pages/contact" class="mobile-nav-link {% if request.path contains '/contact' %}active{% endif %}">Contact</a>
  </nav>
</div>

<!-- CART OVERLAY + DRAWER -->
<div id="cartOverlay" class="cart-drawer-overlay"></div>
<div id="cartDrawer" class="cart-drawer" aria-modal="true" role="dialog">
  <div class="cart-drawer-header">
    <h3>Shopping Cart</h3>
    <button id="closeCartBtn" class="close-drawer-btn" aria-label="Close Shopping Cart">&times;</button>
  </div>
  <div class="cart-drawer-body">
    <div id="cartDrawerItems"></div>
  </div>
  <div class="cart-drawer-footer">
    <div class="cart-subtotal-row">
      <span>Subtotal</span>
      <span id="cartSubtotalAmount">$0.00</span>
    </div>
    <p>Shipping and taxes calculated at checkout.</p>
    <a id="cartViewCartBtn" href="/cart" class="btn btn-primary btn-full" style="margin-bottom: 12px;">View Cart</a>
    <a id="cartCheckoutBtn" href="/checkout" class="btn btn-secondary btn-full" style="margin: 0;">Checkout</a>
  </div>
</div>

<style>
.hero-wrapper {
  position: relative;
  background: linear-gradient(135deg, #F0F4F8 0%, #FFFFFF 100%);
  min-height: 100vh;
}

.hero-logo { color: var(--color-primary); }
.hero-nav-link { color: var(--color-text-primary); }
.hero-nav-link:hover, .hero-nav-link.active { color: var(--color-primary); }
.hero-cart-btn { color: var(--color-text-primary); }
.hero-header .menu-toggle { color: var(--color-text-primary); }

.hero-section {
  padding-top: var(--header-height, 80px);
  padding-bottom: 60px;
  min-height: 100vh;
  display: flex;
  align-items: flex-start;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: center;
  width: 100%;
}

.hero-title {
  font-size: clamp(28px, 4vw, 46px);
  letter-spacing: -0.03em;
  line-height: 1.0;
  white-space: nowrap;
}

@media (max-width: 600px) {
  .hero-title {
    white-space: normal;
    font-size: clamp(26px, 7vw, 34px);
  }
}

.hero-cta-row {
  display: flex;
  gap: 16px;
  align-items: center;
  flex-wrap: wrap;
}

.intro-word {
  display: inline-block;
  opacity: 0;
}

.hero-subheading {
  opacity: 0;
  transform: translateY(10px);
}

#heroCtaRow {
  opacity: 0;
  transform: translateY(10px);
}

.hero-img-mockup {
  position: relative;
  overflow: hidden;
  border-radius: 16px;
  opacity: 0;
  transform: scale(0.96);
  animation: heroImageEntrance 900ms cubic-bezier(0.16, 1, 0.3, 1) 200ms forwards;
}

.hero-img-mockup::after {
  content: "";
  position: absolute;
  top: 0;
  left: -150%;
  width: 60%;
  height: 100%;
  background: linear-gradient(
    100deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.22) 50%,
    rgba(58, 125, 82, 0.12) 70%,
    rgba(255, 255, 255, 0) 100%
  );
  pointer-events: none;
  animation: heroLightSweep 7s ease-in-out 1.4s infinite;
}

@keyframes heroImageEntrance {
  from {
    opacity: 0;
    transform: scale(0.96);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes heroLightSweep {
  0% {
    left: -150%;
  }
  30% {
    left: 150%;
  }
  100% {
    left: 150%;
  }
}

@media (prefers-reduced-motion: reduce) {
  .hero-img-mockup {
    opacity: 1;
    transform: none;
    animation: none;
  }
  .hero-img-mockup::after {
    animation: none;
    display: none;
  }
  .intro-word {
    opacity: 1;
  }
  .hero-subheading {
    opacity: 1;
    transform: none;
  }
  #heroCtaRow {
    opacity: 1;
    transform: none;
  }
}

@media (max-width: 768px) {
  .hero-section {
    padding-top: 0;
    padding-bottom: 48px;
    min-height: auto;
    align-items: flex-start;
  }
  .hero-grid {
    display: flex;
    flex-direction: column;
    text-align: center;
    gap: 24px;
  }
  /* Image flush below navbar, full-bleed */
  .hero-img-container {
    order: -1;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    margin-top: var(--header-height, 80px);
  }
  /* Text content gets top padding so it breathes below the image */
  .hero-content {
    padding-top: 28px;
  }
  /* Remove the circular padded mockup styling on mobile */
  .hero-img-mockup {
    padding: 0;
    background: none;
    border-radius: 0;
    width: 100%;
  }
  /* Full-bleed image */
  .hero-img-mockup img {
    width: 100% !important;
    max-width: 100% !important;
    min-height: 60vw !important;
    height: auto !important;
    object-fit: cover;
    border-radius: 0 !important;
    display: block;
  }
  .hero-cta-row { justify-content: center; }
}
</style>

<script>
(function(){
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  var words = document.querySelectorAll('#heroSection .intro-word');
  var subheading = document.querySelector('#heroSection .hero-subheading');
  var ctaRow = document.getElementById('heroCtaRow');
  var staggerBudget = 300;
  var stagger = words.length ? Math.min(32, staggerBudget / words.length) : 32;
  var wordTransition = 560;

  words.forEach(function(w){
    var dx = (Math.random() * 90 - 45).toFixed(0);
    var dy = (Math.random() * 70 - 35).toFixed(0);
    var rot = (Math.random() * 18 - 9).toFixed(1);
    w.style.transform = 'translate(' + dx + 'px,' + dy + 'px) rotate(' + rot + 'deg)';
  });
  void document.body.offsetHeight;
  words.forEach(function(w, i){
    var delay = i * stagger;
    w.style.transition = 'transform ' + wordTransition + 'ms cubic-bezier(0.16,1,0.3,1) ' + delay + 'ms, opacity 420ms ease-out ' + delay + 'ms';
    w.style.opacity = '1';
    w.style.transform = 'translate(0,0) rotate(0deg)';
  });

  var wordsFinishAt = words.length ? (words.length - 1) * stagger + wordTransition : 0;
  var ctaDelay = wordsFinishAt + 100;

  if (subheading) {
    var subDelay = wordsFinishAt + 80;
    subheading.style.transition = 'opacity 480ms ease-out ' + subDelay + 'ms, transform 480ms cubic-bezier(0.16,1,0.3,1) ' + subDelay + 'ms';
    subheading.style.opacity = '1';
    subheading.style.transform = 'translateY(0)';
    ctaDelay = subDelay + 480 + 60;
  }

  if (ctaRow) {
    ctaRow.style.transition = 'opacity 480ms ease-out ' + ctaDelay + 'ms, transform 480ms cubic-bezier(0.16,1,0.3,1) ' + ctaDelay + 'ms';
    ctaRow.style.opacity = '1';
    ctaRow.style.transform = 'translateY(0)';
  }
})();
</script>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Stand Straight. Feel Better." },
    { "type": "text", "id": "title", "label": "Heading", "default": "Your Posture Shapes Your Life" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Verta is PostureTru's posture awareness trainer, built to bring your attention back the moment a long day starts to take it. A gentle vibration meets the first sign of slouching, helping you build better posture as you work, study, or play." },
    { "type": "text", "id": "cta_text", "label": "CTA Text", "default": "Shop Verta" },
    { "type": "url", "id": "cta_link", "label": "CTA Link" }
  ],
  "presets": [{ "name": "Hero Banner", "category": "Hero" }]
}
{% endschema %}