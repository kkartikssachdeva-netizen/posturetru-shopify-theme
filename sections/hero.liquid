{% comment %}
  Hero Banner - sections/hero.liquid
  Modified: Replaced SVG placeholder with scroll-driven 2-image showcase
  Images: frame1_slouched (load state) → frame4_upright (scroll state)
  Removed: posture-scroll-animation section (merged here)
{% endcomment %}

<section class="hero" id="heroSection">
  <div class="container grid grid-2" style="align-items: center;">

    <!-- LEFT: Text content (unchanged) -->
    <div class="hero-content">
      <span class="hero-tagline">{{ section.settings.tagline | default: 'Stand Straight. Feel Better.' }}</span>
      <h1 class="hero-title">{{ section.settings.title | default: 'Your Posture Shapes Your Life' }}</h1>
      <p class="hero-subheading">{{ section.settings.subheading | default: 'Professional-grade posture correction for remote workers who refuse to compromise on health' }}</p>
      <div style="display:flex; gap:16px; align-items:center; flex-wrap:wrap;">
        <a href="{{ section.settings.cta_link | default: '/pages/shop' }}" class="btn btn-primary">
          {{ section.settings.cta_text | default: 'Shop PostureTru' }}
        </a>
        <a href="#PillarsSection" class="btn btn-outline">Learn More</a>
      </div>
    </div>

    <!-- RIGHT: Scroll-driven image showcase (replaces SVG) -->
    <div class="hero-img-container">
      <div class="hero-img-mockup hero-img-scroll-wrap">

        <!-- Frame 1: visible on load -->
        <img
          id="heroFrame1"
          src="https://cdn.shopify.com/s/files/1/0839/9274/0080/files/frame1_slouched.jpg?v=1780984466"
          alt="PostureTru posture corrector - before"
          loading="eager"
          class="hero-scroll-img hero-scroll-img--top">

        <!-- Frame 4: fades in on scroll -->
        <img
          id="heroFrame4"
          src="https://cdn.shopify.com/s/files/1/0839/9274/0080/files/frame4_upright.jpg?v=1780984466"
          alt="PostureTru posture corrector - after"
          loading="lazy"
          class="hero-scroll-img hero-scroll-img--bottom">

      </div>

      <!-- Trust badge (unchanged) -->
        </svg>
      </div>
    </div>

  </div>
</section>

<style>
  /* Image showcase wrapper */
  .hero-img-scroll-wrap {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(27, 73, 101, 0.18);
    background: #F0F4F8;
    /* Let the image define the height naturally */
    width: 100%;
  }

  /* Both images share the same space */
  .hero-scroll-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain; /* Never crop */
    transition: opacity 0.7s ease, transform 0.8s ease;
  }

  /* Frame 1: on top, fully visible */
  .hero-scroll-img--top {
    position: relative;
    z-index: 2;
    opacity: 1;
    transform: scale(1);
  }

  /* Frame 4: underneath, hidden until scroll */
  .hero-scroll-img--bottom {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0;
    transform: scale(1.04);
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Mobile: stack image above text, centered, max width */
  @media (max-width: 768px) {
    #heroSection .grid-2 {
      display: flex !important;
      flex-direction: column-reverse;
      gap: 28px;
    }
    .hero-img-scroll-wrap {
      max-width: 400px;
      margin: 0 auto;
    }
  }
</style>

<script>
(function () {
  /* Preload frame 4 immediately so transition is instant */
  var pre = new Image();
  pre.src = 'https://cdn.shopify.com/s/files/1/0839/9274/0080/files/frame4_upright.jpg?v=1780984466';

  document.addEventListener('DOMContentLoaded', function () {
    var hero    = document.getElementById('heroSection');
    var frame1  = document.getElementById('heroFrame1');
    var frame4  = document.getElementById('heroFrame4');
    var ticking = false;
    var state   = 'before'; /* track current state to avoid redundant style sets */

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }

    function update() {
      var rect     = hero.getBoundingClientRect();
      var progress = Math.min(Math.max(-rect.top / 60, 0), 1);

      if (progress >= 0.1 && state !== 'after') {
        /* Transition to frame 4 */
        state = 'after';
        frame1.style.opacity   = '0';
        frame1.style.transform = 'scale(1.04)';
        frame4.style.opacity   = '1';
        frame4.style.transform = 'scale(1)';
        frame4.style.zIndex    = '2';
        frame1.style.zIndex    = '1';
      } else if (progress < 0.35 && state !== 'before') {
        /* Reverse on scroll up */
        state = 'before';
        frame1.style.opacity   = '1';
        frame1.style.transform = 'scale(1)';
        frame4.style.opacity   = '0';
        frame4.style.transform = 'scale(1.04)';
        frame4.style.zIndex    = '1';
        frame1.style.zIndex    = '2';
      }

      ticking = false;
    }

    window.addEventListener('scroll', onScroll, { passive: true });
  });
})();
</script>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Stand Straight. Feel Better."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Your Posture Shapes Your Life"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Professional-grade posture correction for remote workers who refuse to compromise on health"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Shop PostureTru"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Hero"
    }
  ]
}
{% endschema %}
