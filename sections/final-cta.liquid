<section class="final-cta section-padding">
  <div class="container">
    <h2>{{ section.settings.title | default: 'Better Posture Starts With Awareness' }}</h2>
    <p>{{ section.settings.copy | default: 'PostureTru is designed to help you build better posture habits over time, one gentle reminder at a time. Try it for yourself and notice the difference awareness can make.' }}</p>
    <div>
      <a href="{{ section.settings.cta_link | default: '/products/posturetru' }}" class="btn final-cta-btn">
        {{ section.settings.cta_text | default: 'Get PostureTru Today' }}
      </a>
    </div>
    <span class="final-cta-subtext">{{ section.settings.sub_text | default: '30 day satisfaction guarantee. Free shipping on all orders.' }}</span>
  </div>
</section>

{% schema %}
{
  "name": "Final CTA",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Better Posture Starts With Awareness"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Description",
      "default": "PostureTru is designed to help you build better posture habits over time, one gentle reminder at a time. Try it for yourself and notice the difference awareness can make."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Get PostureTru Today"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    },
    {
      "type": "text",
      "id": "sub_text",
      "label": "Subheading Subtext",
      "default": "30 day satisfaction guarantee. Free shipping on all orders."
    }
  ],
  "presets": [
    {
      "name": "Final CTA",
      "category": "Hero"
    }
  ]
}
{% endschema %}
