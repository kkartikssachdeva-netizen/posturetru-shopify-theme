{% assign product = all_products['smart-posture-corrector-miicro-vibration-posture-training-reminder-sensor-back-posture-neck-hump-corrector-for-adult-kids'] %}

<!-- PRODUCT HERO -->
<section class="section-padding">
  <div class="container product-template-grid">

    <!-- Gallery Column -->
    <div class="product-gallery">
      <div id="mainImageContainer" class="main-image-viewport">
        <img id="mainImage" src="{{ product.featured_image | img_url: '800x800' }}" alt="{{ product.title }}" style="width:100%; border-radius:12px;">
      </div>
      <div class="thumbnail-strip">
        {% for image in product.images %}
          <button class="thumb-button {% if forloop.first %}active{% endif %}" onclick="document.getElementById('mainImage').src='{{ image | img_url: '800x800' }}'; document.querySelectorAll('.thumb-button').forEach(b=>b.classList.remove('active')); this.classList.add('active');">
            <img src="{{ image | img_url: '200x200' }}" alt="{{ product.title }}" style="width:100%; border-radius:6px;">
          </button>
        {% endfor %}
      </div>
    </div>

    <!-- Info Column -->
    <div class="product-details">
      <span class="badge badge-sale" style="align-self:flex-start; margin-bottom:12px;">50% OFF TODAY</span>
      <h1 class="product-title">{{ product.title }}</h1>

      <div class="product-meta-row">
        <div class="reviews-badge" onclick="document.getElementById('ReviewsBlock').scrollIntoView({behavior:'smooth'})">
          <div class="star-rating">
            {% for i in (1..5) %}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            {% endfor %}
          </div>
          <span>4.9 (1,248 reviews)</span>
        </div>
      </div>

      <div class="product-pricing" style="margin:16px 0;">
        <div style="display:flex; align-items:baseline; gap:12px; flex-wrap:wrap;">
          <span style="font-size:42px; font-weight:900; color:#1B4965; letter-spacing:-1px; line-height:1;">$39.99 CAD</span>
          <span style="font-size:22px; color:#aaa; font-weight:400; text-decoration:line-through; text-decoration-color:#E74C3C; text-decoration-thickness:2px;">$79.99 CAD</span>
        </div>
        <div style="display:flex; align-items:center; gap:10px; margin-top:8px;">
          <span style="background:#E74C3C; color:white; font-size:11px; font-weight:700; padding:3px 10px; border-radius:20px; letter-spacing:0.1em; text-transform:uppercase;">50% OFF</span>
          <span style="color:#5FB878; font-size:13px; font-weight:600;">🎉 You save $40.00 CAD!</span>
        </div>
      </div>

      <p class="product-short-description">PostureTru is not a generic posture brace. It's an intelligent, wearable posture trainer designed specifically for remote workers, office professionals, and anyone who spends hours sitting. Unlike passive braces, our Smart Vibration Posture Corrector detects slouching in real-time and gives you immediate vibration feedback.</p>

      <!-- ATC Box -->
      <form id="product-form"><input type="hidden" name="return_to" value="/cart">

        <!-- Variant Selector -->
<div style="margin-bottom:16px;">
          <span style="font-size:13px; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; display:block; margin-bottom:10px;">Select Color</span>
          <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <button type="button" class="size-option-btn active" onclick="document.getElementById('variantId').value='49818098630896';document.querySelectorAll('.size-option-btn').forEach(b=>b.classList.remove('active'));this.classList.add('active');" style="display:flex;align-items:center;gap:8px;padding:10px 20px;border:2px solid #1B4965;border-radius:8px;background:white;cursor:pointer;font-weight:600;font-size:14px;">
              <span style="width:16px;height:16px;border-radius:50%;background:#1a1a1a;display:inline-block;border:1px solid rgba(0,0,0,0.15);"></span>
              Black
            </button>
            <button type="button" class="size-option-btn" onclick="document.getElementById('variantId').value='49818098663664';document.querySelectorAll('.size-option-btn').forEach(b=>b.classList.remove('active'));this.classList.add('active');" style="display:flex;align-items:center;gap:8px;padding:10px 20px;border:2px solid #1B4965;border-radius:8px;background:white;cursor:pointer;font-weight:600;font-size:14px;">
              <span style="width:16px;height:16px;border-radius:50%;background:#E8751A;display:inline-block;border:1px solid rgba(0,0,0,0.15);"></span>
              Orange
            </button>
          </div>
        </div>
        <input type="hidden" name="id" id="variantId" value="49818098630896">

        <!-- Quantity + ATC -->
        <div class="quantity-row">
          <div class="quantity-selector">
            <button type="button" class="qty-btn" onclick="let q=document.getElementById('productQty'); if(q.value>1) q.value=parseInt(q.value)-1;">-</button>
            <input type="number" id="productQty" name="quantity" class="qty-input" value="1" min="1">
            <button type="button" class="qty-btn" onclick="let q=document.getElementById('productQty'); q.value=parseInt(q.value)+1;">+</button>
          </div>
          <button type="button" onclick="addToCart()" class="btn btn-secondary btn-full" style="flex:1; margin:0;">Add to Cart</button>
        </div>

        <div class="shipping-promo-box">
          {% render 'icon-truck' %}
          <div class="shipping-promo-text">
            <strong>FREE Tracked Shipping</strong> to US, Canada, and Australia. Standard delivery: 5-7 business days.
          </div>
        </div>

      </form>
    </div>
  </div>
<script>
function addToCart() {
  var variantId = document.getElementById("variantId").value;
  var quantity = document.getElementById("productQty").value;
  fetch("/cart/add.js", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ id: parseInt(variantId), quantity: parseInt(quantity) })
  })
  .then(function(res) {
    if (res.ok) { window.location.href = "/cart"; }
    else { res.json().then(function(d) { alert("Error: " + d.description); }); }
  })
  .catch(function() { alert("Something went wrong. Please try again."); });
}
</script>
</section>

{% section 'product-features' %}
{% section 'product-benefits' %}
{% section 'product-specs' %}
{% section 'guarantees' %}

<!-- Reviews Section -->
<section id="ReviewsBlock" class="section-padding reviews-section" style="background-color: var(--color-bg);">
  <div class="container">
    <div class="reviews-header-block">
      <div class="reviews-score">
        <span class="reviews-score-num">4.9</span>
        <div class="reviews-score-stars">
          <div class="star-rating">
            {% for i in (1..5) %}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            {% endfor %}
          </div>
          <p>Based on 1,248 Verified Customer Reviews</p>
        </div>
      </div>
    </div>
    <div class="reviews-list">
      <div class="review-card">
        <div class="review-card-meta">
          <span class="reviewer-name">Sarah M. <span class="reviewer-verified">Verified Buyer</span></span>
          <span class="review-date">2 weeks ago</span>
        </div>
        <div class="star-rating" style="margin-bottom:8px; color:var(--color-accent);">{% for i in (1..5) %}<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>{% endfor %}</div>
        <h4 class="review-title">Best WFH purchase I have made!</h4>
        <p class="review-body">I've been using PostureTru for 2 weeks and the difference is night and day. My back pain is gone and I feel more energized at my desk.</p>
      </div>
      <div class="review-card">
        <div class="review-card-meta">
          <span class="reviewer-name">James T. <span class="reviewer-verified">Verified Buyer</span></span>
          <span class="review-date">3 weeks ago</span>
        </div>
        <div class="star-rating" style="margin-bottom:8px; color:var(--color-accent);">{% for i in (1..5) %}<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>{% endfor %}</div>
        <h4 class="review-title">The vibration reminders are genius</h4>
        <p class="review-body">As a software developer, I slouch constantly. The light vibrations keep me honest and train my posture muscle memory naturally.</p>
      </div>
      <div class="review-card">
        <div class="review-card-meta">
          <span class="reviewer-name">Lisa K. <span class="reviewer-verified">Verified Buyer</span></span>
          <span class="review-date">1 month ago</span>
        </div>
        <div class="star-rating" style="margin-bottom:8px; color:var(--color-accent);">{% for i in (1..5) %}<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>{% endfor %}</div>
        <h4 class="review-title">Excellent quality and comfort</h4>
        <p class="review-body">Quality is exceptional. The materials are comfortable, the fit is perfect, and it actually works. Completely invisible under my sweaters.</p>
      </div>
    </div>
  </div>

</section>

