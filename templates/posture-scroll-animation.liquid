        <div class="posture-step" data-frame="https://cdn.shopify.com/s/files/1/0839/9274/0080/files/frame3_correcting.jpg?v=1780984466" data-light="#27AE60" data-shadow="rgba(39,174,96,0.5)" style="padding:60px 0; border-bottom:1px solid #E8ECEB;">
          <div style="display:inline-block; background:#EDFAF3; color:#27AE60; font-size:12px; font-weight:700; padding:4px 12px; border-radius:20px; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:16px;">💪 The Response</div>
