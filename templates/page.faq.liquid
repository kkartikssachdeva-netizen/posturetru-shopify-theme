{% comment %}
  PostureTru FAQ Page Template
{% endcomment %}

<section class="about-hero" id="faqPageHeroSection">
  <div class="container">
    <h1 style="font-size: clamp(22px, 6vw, 48px); margin-bottom: 16px; white-space: nowrap;"><span class="intro-word">Frequently</span>&nbsp;<span class="intro-word">Asked</span>&nbsp;<span class="intro-word">Questions</span></h1>
    <p class="entrance-fade" style="font-size: 18px; color: var(--color-text-secondary); max-width: 600px; margin: 0 auto;">
      Have questions? We have answers.
    </p>
  </div>
</section>

<script>
(function(){
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  var section = document.getElementById('faqPageHeroSection');
  if (!section) return;
  var words = section.querySelectorAll('.intro-word');
  var fade = section.querySelector('.entrance-fade');
  var staggerBudget = 300;
  var stagger = words.length ? Math.min(32, staggerBudget / words.length) : 32;
  var wordTransition = 560;
  words.forEach(function(w){
    var dx = (Math.random() * 90 - 45).toFixed(0);
    var dy = (Math.random() * 70 - 35).toFixed(0);
    var rot = (Math.random() * 18 - 9).toFixed(1);
    w.style.transform = 'translate(' + dx + 'px,' + dy + 'px) rotate(' + rot + 'deg)';
  });
  void document.body.offsetHeight;
  words.forEach(function(w, i){
    var delay = i * stagger;
    w.style.transition = 'transform ' + wordTransition + 'ms cubic-bezier(0.16,1,0.3,1) ' + delay + 'ms, opacity 420ms ease-out ' + delay + 'ms';
    w.style.opacity = '1';
    w.style.transform = 'translate(0,0) rotate(0deg)';
  });
  var finishAt = words.length ? (words.length - 1) * stagger + wordTransition : 0;
  if (fade) {
    var fadeDelay = finishAt + 80;
    fade.style.transition = 'opacity 480ms ease-out ' + fadeDelay + 'ms, transform 480ms cubic-bezier(0.16,1,0.3,1) ' + fadeDelay + 'ms';
    fade.style.opacity = '1';
    fade.style.transform = 'translateY(0)';
  }
})();
</script>

<section class="section-padding">
  <div class="container">
    {% include 'faq-data' %}

    <!-- About Category -->
    <div style="margin-bottom: 60px;">
      <h3 style="color: var(--color-primary); font-size: 24px; border-bottom: 1px solid var(--color-border); padding-bottom: 12px; margin-bottom: 24px;">About PostureTru</h3>
      <div class="faq-accordion-container">
        {% render 'faq-item', id: 'what-is', question: faq_q_what_is, answer: faq_a_what_is %}
        {% render 'faq-item', id: 'different', question: faq_q_different, answer: faq_a_different %}
        {% render 'faq-item', id: 'who', question: faq_q_who, answer: faq_a_who %}
      </div>
    </div>

    <!-- Results & How It Works Category -->
    <div style="margin-bottom: 60px;">
      <h3 style="color: var(--color-primary); font-size: 24px; border-bottom: 1px solid var(--color-border); padding-bottom: 12px; margin-bottom: 24px;">Results & How It Works</h3>
      <div class="faq-accordion-container">
        {% render 'faq-item', id: 'results', question: faq_q_results, answer: faq_a_results %}
        {% render 'faq-item', id: 'vibration', question: faq_q_vibration, answer: faq_a_vibration %}
      </div>
    </div>

    <!-- Comfort & Wearing Category -->
    <div style="margin-bottom: 60px;">
      <h3 style="color: var(--color-primary); font-size: 24px; border-bottom: 1px solid var(--color-border); padding-bottom: 12px; margin-bottom: 24px;">Comfort & Wearing</h3>
      <div class="faq-accordion-container">
        {% render 'faq-item', id: 'under-clothes', question: faq_q_under_clothes, answer: faq_a_under_clothes %}
        {% render 'faq-item', id: 'all-day-wear', question: faq_q_all_day_wear, answer: faq_a_all_day_wear %}
        {% render 'faq-item', id: 'care', question: faq_q_care, answer: faq_a_care %}
      </div>
    </div>

    <!-- Shipping & Returns Category -->
    <div>
      <h3 style="color: var(--color-primary); font-size: 24px; border-bottom: 1px solid var(--color-border); padding-bottom: 12px; margin-bottom: 24px;">Shipping & Returns</h3>
      <div class="faq-accordion-container">
        {% render 'faq-item', id: 'shipping-time', question: faq_q_shipping_time, answer: faq_a_shipping_time %}
        {% render 'faq-item', id: 'international', question: faq_q_international, answer: faq_a_international %}
        {% render 'faq-item', id: 'returns', question: faq_q_returns, answer: faq_a_returns %}
      </div>
    </div>

  </div>
</section>
