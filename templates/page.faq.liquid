{% comment %}
  PostureTru FAQ Page Template
{% endcomment %}

<section class="about-hero">
  <div class="container">
    <h1 style="font-size: 48px; margin-bottom: 16px;">{{ page.title | default: 'Frequently Asked Questions' }}</h1>
    <p style="font-size: 18px; color: var(--color-text-secondary); max-width: 600px; margin: 0 auto;">
      Everything you need to know about PostureTru.
    </p>
  </div>
</section>

<section class="section-padding">
  <div class="container">
    {% capture faq_json %}{% render 'faq-data' %}{% endcapture %}
    {% assign faq_items = faq_json | parse_json %}

    <!-- About Category -->
    <div style="margin-bottom: 60px;">
      <h3 style="color: var(--color-primary); font-size: 24px; border-bottom: 2px solid var(--color-primary); padding-bottom: 10px; margin-bottom: 24px;">About PostureTru</h3>
      <div class="faq-accordion-container">
        {% assign about_ids = "what-is,different,who" | split: "," %}
        {% for id in about_ids %}
          {% assign item = faq_items | where: "id", id | first %}
          {% render 'faq-item', item: item %}
        {% endfor %}
      </div>
    </div>

    <!-- Results & How It Works Category -->
    <div style="margin-bottom: 60px;">
      <h3 style="color: var(--color-primary); font-size: 24px; border-bottom: 2px solid var(--color-primary); padding-bottom: 10px; margin-bottom: 24px;">Results & How It Works</h3>
      <div class="faq-accordion-container">
        {% assign works_ids = "results,vibration" | split: "," %}
        {% for id in works_ids %}
          {% assign item = faq_items | where: "id", id | first %}
          {% render 'faq-item', item: item %}
        {% endfor %}
      </div>
    </div>

    <!-- Comfort & Wearing Category -->
    <div style="margin-bottom: 60px;">
      <h3 style="color: var(--color-primary); font-size: 24px; border-bottom: 2px solid var(--color-primary); padding-bottom: 10px; margin-bottom: 24px;">Comfort & Wearing</h3>
      <div class="faq-accordion-container">
        {% assign wear_ids = "under-clothes,all-day-wear,care" | split: "," %}
        {% for id in wear_ids %}
          {% assign item = faq_items | where: "id", id | first %}
          {% render 'faq-item', item: item %}
        {% endfor %}
      </div>
    </div>

    <!-- Shipping & Returns Category -->
    <div>
      <h3 style="color: var(--color-primary); font-size: 24px; border-bottom: 2px solid var(--color-primary); padding-bottom: 10px; margin-bottom: 24px;">Shipping & Returns</h3>
      <div class="faq-accordion-container">
        {% assign ship_ids = "shipping-time,international,returns" | split: "," %}
        {% for id in ship_ids %}
          {% assign item = faq_items | where: "id", id | first %}
          {% render 'faq-item', item: item %}
        {% endfor %}
      </div>
    </div>

  </div>
</section>
