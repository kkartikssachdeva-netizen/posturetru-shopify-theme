{% comment %}
  PostureTru FAQ Page Template
{% endcomment %}

<section class="about-hero">
  <div class="container">
    <h1 style="font-size: 48px; margin-bottom: 16px;">{{ page.title | default: 'Frequently Asked Questions' }}</h1>
    <p style="font-size: 18px; color: var(--color-text-secondary); max-width: 600px; margin: 0 auto;">
      Everything you need to know about PostureTru.
    </p>
  </div>
</section>

<section class="section-padding">
  <div class="container">
    
    <!-- About Category -->
    <div style="margin-bottom: 60px;">
      <h3 style="color: var(--color-primary); font-size: 24px; border-bottom: 2px solid var(--color-primary); padding-bottom: 10px; margin-bottom: 24px;">About PostureTru</h3>
      <div class="faq-accordion-container">
        
        <div class="accordion-item">
          <button class="accordion-header" aria-expanded="false" aria-controls="faq-about-1">
            What is PostureTru?
            <span class="accordion-icon">+</span>
          </button>
          <div id="faq-about-1" class="accordion-content" role="region">
            <div class="accordion-content-inner">
              PostureTru is a smart posture corrector designed specifically for remote workers. It uses a high-precision gyroscope chip to detect slouching in real time and delivers a gentle vibration reminder — training your body to self-correct naturally.
            </div>
          </div>
        </div>

        <div class="accordion-item">
          <button class="accordion-header" aria-expanded="false" aria-controls="faq-about-2">
            How is PostureTru different from other posture braces?
            <span class="accordion-icon">+</span>
          </button>
          <div id="faq-about-2" class="accordion-content" role="region">
            <div class="accordion-content-inner">
              Most posture braces are uncomfortable and restrict movement. PostureTru is engineered with breathable materials, adjustable fit, and smart vibration technology that actually trains your posture instead of just forcing it.
            </div>
          </div>
        </div>

        <div class="accordion-item">
          <button class="accordion-header" aria-expanded="false" aria-controls="faq-about-3">
            Who should use PostureTru?
            <span class="accordion-icon">+</span>
          </button>
          <div id="faq-about-3" class="accordion-content" role="region">
            <div class="accordion-content-inner">
              Anyone who spends hours at a desk—remote workers, office employees, students, or professionals. If you experience back pain, neck stiffness, or poor posture, PostureTru is for you.
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Results & How It Works Category -->
    <div style="margin-bottom: 60px;">
      <h3 style="color: var(--color-primary); font-size: 24px; border-bottom: 2px solid var(--color-primary); padding-bottom: 10px; margin-bottom: 24px;">Results & How It Works</h3>
      <div class="faq-accordion-container">
        
        <div class="accordion-item">
          <button class="accordion-header" aria-expanded="false" aria-controls="faq-works-1">
            How long before I see results?
            <span class="accordion-icon">+</span>
          </button>
          <div id="faq-works-1" class="accordion-content" role="region">
            <div class="accordion-content-inner">
              Most users report noticeable improvement within 3-7 days. Optimal results typically appear within 2-4 weeks as your muscles adjust to proper posture.
            </div>
          </div>
        </div>

        <div class="accordion-item">
          <button class="accordion-header" aria-expanded="false" aria-controls="faq-works-2">
            How does the vibration feedback work?
            <span class="accordion-icon">+</span>
          </button>
          <div id="faq-works-2" class="accordion-content" role="region">
            <div class="accordion-content-inner">
              Sensors detect when you start to slouch and send a gentle vibration alert. Over time, your body learns to associate slouching with the alert, creating new posture habits.
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Comfort & Wearing Category -->
    <div style="margin-bottom: 60px;">
      <h3 style="color: var(--color-primary); font-size: 24px; border-bottom: 2px solid var(--color-primary); padding-bottom: 10px; margin-bottom: 24px;">Comfort & Wearing</h3>
      <div class="faq-accordion-container">
        
        <div class="accordion-item">
          <button class="accordion-header" aria-expanded="false" aria-controls="faq-wear-1">
            Will it show under my clothes?
            <span class="accordion-icon">+</span>
          </button>
          <div id="faq-wear-1" class="accordion-content" role="region">
            <div class="accordion-content-inner">
              No. PostureTru has a slim profile and comes in neutral colors. It's designed to be worn discreetly under any shirt.
            </div>
          </div>
        </div>

        <div class="accordion-item">
          <button class="accordion-header" aria-expanded="false" aria-controls="faq-wear-2">
            Is it comfortable for all-day wear?
            <span class="accordion-icon">+</span>
          </button>
          <div id="faq-wear-2" class="accordion-content" role="region">
            <div class="accordion-content-inner">
              Yes. PostureTru uses breathable medical-grade materials with adjustable straps for a custom fit. Many users forget they're wearing it after the first few days.
            </div>
          </div>
        </div>

        <div class="accordion-item">
          <button class="accordion-header" aria-expanded="false" aria-controls="faq-wear-3">
            How do I care for it?
            <span class="accordion-icon">+</span>
          </button>
          <div id="faq-wear-3" class="accordion-content" role="region">
            <div class="accordion-content-inner">
              Simply hand wash with mild soap and air dry. It lasts years with proper care.
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Shipping & Returns Category -->
    <div>
      <h3 style="color: var(--color-primary); font-size: 24px; border-bottom: 2px solid var(--color-primary); padding-bottom: 10px; margin-bottom: 24px;">Shipping & Returns</h3>
      <div class="faq-accordion-container">
        
        <div class="accordion-item">
          <button class="accordion-header" aria-expanded="false" aria-controls="faq-ship-1">
            How long does shipping take?
            <span class="accordion-icon">+</span>
          </button>
          <div id="faq-ship-1" class="accordion-content" role="region">
            <div class="accordion-content-inner">
              We ship within 5-7 business days to US, Canada, and Australia. Processing takes 1-2 business days.
            </div>
          </div>
        </div>

        <div class="accordion-item">
          <button class="accordion-header" aria-expanded="false" aria-controls="faq-ship-2">
            Do you ship internationally?
            <span class="accordion-icon">+</span>
          </button>
          <div id="faq-ship-2" class="accordion-content" role="region">
            <div class="accordion-content-inner">
              Currently we ship to US, Canada, and Australia. International shipping coming soon. Contact us for inquiries.
            </div>
          </div>
        </div>

        <div class="accordion-item">
          <button class="accordion-header" aria-expanded="false" aria-controls="faq-ship-3">
            What's your return policy?
            <span class="accordion-icon">+</span>
          </button>
          <div id="faq-ship-3" class="accordion-content" role="region">
            <div class="accordion-content-inner">
              We offer a 30-day money-back guarantee. If you're not satisfied, return it for a full refund—no questions asked.
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>
