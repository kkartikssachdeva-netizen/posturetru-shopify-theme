{% comment %}
  PostureTru FAQ Page Template
{% endcomment %}

<section class="about-hero">
  <div class="container">
    <h1 style="font-size: 48px; margin-bottom: 16px;">{{ page.title | default: 'Frequently Asked Questions' }}</h1>
    <p style="font-size: 18px; color: var(--color-text-secondary); max-width: 600px; margin: 0 auto;">
      Everything you need to know about PostureTru.
    </p>
  </div>
</section>

<section class="section-padding">
  <div class="container">
    {% include 'faq-data' %}

    <!-- About Category -->
    <div style="margin-bottom: 60px;">
      <h3 style="color: var(--color-primary); font-size: 24px; border-bottom: 2px solid var(--color-primary); padding-bottom: 10px; margin-bottom: 24px;">About PostureTru</h3>
      <div class="faq-accordion-container">
        {% render 'faq-item', id: 'what-is', question: faq_q_what_is, answer: faq_a_what_is %}
        {% render 'faq-item', id: 'different', question: faq_q_different, answer: faq_a_different %}
        {% render 'faq-item', id: 'who', question: faq_q_who, answer: faq_a_who %}
      </div>
    </div>

    <!-- Results & How It Works Category -->
    <div style="margin-bottom: 60px;">
      <h3 style="color: var(--color-primary); font-size: 24px; border-bottom: 2px solid var(--color-primary); padding-bottom: 10px; margin-bottom: 24px;">Results & How It Works</h3>
      <div class="faq-accordion-container">
        {% render 'faq-item', id: 'results', question: faq_q_results, answer: faq_a_results %}
        {% render 'faq-item', id: 'vibration', question: faq_q_vibration, answer: faq_a_vibration %}
      </div>
    </div>

    <!-- Comfort & Wearing Category -->
    <div style="margin-bottom: 60px;">
      <h3 style="color: var(--color-primary); font-size: 24px; border-bottom: 2px solid var(--color-primary); padding-bottom: 10px; margin-bottom: 24px;">Comfort & Wearing</h3>
      <div class="faq-accordion-container">
        {% render 'faq-item', id: 'under-clothes', question: faq_q_under_clothes, answer: faq_a_under_clothes %}
        {% render 'faq-item', id: 'all-day-wear', question: faq_q_all_day_wear, answer: faq_a_all_day_wear %}
        {% render 'faq-item', id: 'care', question: faq_q_care, answer: faq_a_care %}
      </div>
    </div>

    <!-- Shipping & Returns Category -->
    <div>
      <h3 style="color: var(--color-primary); font-size: 24px; border-bottom: 2px solid var(--color-primary); padding-bottom: 10px; margin-bottom: 24px;">Shipping & Returns</h3>
      <div class="faq-accordion-container">
        {% render 'faq-item', id: 'shipping-time', question: faq_q_shipping_time, answer: faq_a_shipping_time %}
        {% render 'faq-item', id: 'international', question: faq_q_international, answer: faq_a_international %}
        {% render 'faq-item', id: 'returns', question: faq_q_returns, answer: faq_a_returns %}
      </div>
    </div>

  </div>
</section>
